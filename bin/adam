#!/usr/bin/env bash
# adam — Adamomaton agent-coordination CLI.
#
# Subcommands:
#   claim <scope>/<task>      create a worktree + branch + lockfile
#   release <scope>/<task>    push branch (optional), remove worktree, drop lockfile
#   status [--conflicts]      list active claims (and overlapping path warnings)
#   sync-hooks                install hooks/ templates into every submodule
#   deploy <host>             run deploy/<host>/up.sh
#   bump <sub-repo>           advance umbrella's submodule pin to its origin/main HEAD
#   pin <sub-repo>            show current umbrella pin for a sub-repo
#   pull                      git pull + git submodule update --recursive --remote
#   help [subcommand]
#
# Soft coordination: lockfiles in .locks/ describe active work but don't
# physically prevent overlap. The pre-push hook warns when pushing to a
# branch claimed by someone else; you can `--force` past it.

set -euo pipefail

# ---- globals -------------------------------------------------------------

# When invoked as $REPO/bin/adam, ADAM_ROOT is the umbrella root.
ADAM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LOCK_DIR="$ADAM_ROOT/.locks"
HOOKS_DIR="$ADAM_ROOT/hooks"
DEPLOY_DIR="$ADAM_ROOT/deploy"

CURRENT_AGENT="${ADAM_AGENT:-$(git config user.name 2>/dev/null || whoami)}"

# Submodule names recognised as <scope>. "cross" is a special scope that
# means "umbrella-level worktree containing all submodules".
SUBMODULES=(core frontend knowledge deepresearch platform delegator evolve loopvm)

# ---- helpers -------------------------------------------------------------

usage() {
    cat <<'EOF'
Usage: adam <subcommand> [args]

Worktree + branch coordination:
  claim <scope>/<task>      create a worktree + feature branch + lockfile
                            <scope> = one of core|frontend|knowledge|deepresearch|
                                      platform|delegator|evolve|cross
  release <scope>/<task>    remove the worktree, drop the lockfile
                            (--keep-branch to leave the branch unpushed)
  status [--conflicts]      list active claims
  rescue                    detect + recover from "edited main directly" mistakes
  clean [--force]           list (or remove with --force) stale lockfiles

Build + test + verify:
  doctor                    environment health check (git, gh, go, hooks, submodules)
  build <host>              cross-compile + tag images for <host>
                            <host> = pi5 | pi5-speaker | blackwell
  test [--scope=<sub>]      run go test ./... across all (or one) sub-repo
  ci <target> [ref]         local CI (GitHub Actions is banned — this IS the CI).
                            <target> = a sub-repo name | cross | all.
                            Sub-repo: vet+build+test every go module at <ref>
                            (default origin/main) in a throwaway worktree;
                            frontend runs pnpm install + vite build.
                            cross: strict-parse + `compose config -q` every
                            deploy/*/docker-compose.yml, caddy-validate the
                            pi5 Caddyfile, schema-check every MANIFEST.yaml.
                            all: every sub-repo + cross, aggregated (no
                            fail-fast). Set ZTOK_PREFIX to include the
                            libztok cgo modules (knowledge/r2g, reindex).

Hooks + submodules:
  sync-hooks                copy hooks/ templates into each submodule's .git/hooks/
  bump <sub-repo>           advance umbrella's submodule pin to origin/main HEAD
                            (the ONLY supported way to commit on main)
  pin <sub-repo>            print current umbrella SHA pin for a sub-repo
  pull                      umbrella pull + recursive submodule update

Fleet (multi-host rollouts):
  fleet status              show what image_tag each host's MANIFEST.yaml pins
  fleet verify <host|all> [--notify]
                            per-service red/green table (running? healthy?) via
                            the deploy-agent; exits non-zero on any red.
                            --notify POSTs an alert to ADAMATON_ALERT_WEBHOOK
                            (ntfy/webhook, set in ship.env) when red — see the
                            adamaton-fleet-verify.timer in deploy/systemd/.
  fleet pull <host|all>     ssh + docker compose pull + up -d, per host's MANIFEST
  fleet promote <sha-or-tag> [--dry-run]
                            bulk-update every host's MANIFEST to a new tag.
                            Validates each MANIFEST.yaml first (schema +
                            services-vs-compose cross-check); --dry-run shows
                            the would-be edits without touching any file.

Single-host deploy:
  deploy <host>             run deploy/<host>/up.sh (rsync configs + compose up)

Push-deploy (workstation registry -> deploy-agent on host):
  bootstrap <host>          one-shot first-deploy: insecure-registry edit,
                            token gen, image-tags.env init, scp+load the
                            agent, compose up, health check, ship.env update.
                            Idempotent; safe to re-run. Needs ssh + sudo on host.
  ship <host> <service> ... build + push image(s) to the workstation registry,
                            then POST /deploy/restart on <host>.lan for each.
                            Reads token + registry IP from ~/.adamaton/ship.env.
                            Refuses to ship if the sub-repo is git-dirty.
  rollback <host> <svc> [<tag>]
                            redeploy <svc> to a PRIOR registry tag (no rebuild);
                            omit <tag> to list available tags. Verifies via
                            fleet verify. The recovery half of deploy safety.
  ship-self <host>          build + push deploy-agent and restart it on <host>
                            via ssh (the agent cannot self-restart safely).
  sync-compose <host>       scp deploy/<host>/docker-compose.yml (+ .env.example)
                            up to <host>:Adamaton-deploy/. Needed when compose-
                            file changes (new env vars, new service blocks) must
                            land on the host — bin/adam ship only pushes images.
                            Recreate services manually afterwards.

  help [subcommand]
EOF
}

die() { echo "adam: error: $*" >&2; exit 2; }

# Normalize a scope/task string into ($scope $task). Aborts on bad shape.
parse_scope_task() {
    local arg="$1"
    if [[ "$arg" != */* ]]; then
        die "expected <scope>/<task>, got '$arg'"
    fi
    SCOPE="${arg%%/*}"
    TASK="${arg#*/}"
    if [[ -z "$SCOPE" || -z "$TASK" ]]; then
        die "scope and task must both be non-empty"
    fi
    # Sanity-check scope.
    local ok=0
    for s in "${SUBMODULES[@]}" cross; do
        if [[ "$s" == "$SCOPE" ]]; then ok=1; break; fi
    done
    if [[ "$ok" -ne 1 ]]; then
        die "unknown scope '$SCOPE'; valid: ${SUBMODULES[*]} cross"
    fi
}

lock_path() {
    echo "$LOCK_DIR/$1-$2.json"
}

write_lock() {
    local scope="$1" task="$2" branch="$3" worktree="$4" paths="$5"
    local now
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    cat > "$(lock_path "$scope" "$task")" <<EOF
{
  "agent":     "$CURRENT_AGENT",
  "scope":     "$scope",
  "task":      "$task",
  "branch":    "$branch",
  "worktree":  "$worktree",
  "paths":     [$paths],
  "started_at":"$now"
}
EOF
}

git_in() { git -C "$1" "${@:2}"; }

# ---- subcommands ---------------------------------------------------------

cmd_claim() {
    [[ $# -ge 1 ]] || die "claim: missing <scope>/<task>"
    parse_scope_task "$1"
    shift
    # Optional --paths "glob1,glob2,..."
    local paths_csv=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --paths) paths_csv="$2"; shift 2 ;;
            *) die "unknown flag '$1'" ;;
        esac
    done
    local paths_json=""
    if [[ -n "$paths_csv" ]]; then
        IFS=',' read -ra arr <<<"$paths_csv"
        for p in "${arr[@]}"; do
            paths_json+="\"$p\","
        done
        paths_json="${paths_json%,}"
    fi

    local lock_file
    lock_file="$(lock_path "$SCOPE" "$TASK")"
    if [[ -e "$lock_file" ]]; then
        die "claim already exists at $lock_file (use 'release' first, or --force)"
    fi

    local branch="$CURRENT_AGENT/$TASK"
    local worktree_path
    if [[ "$SCOPE" == "cross" ]]; then
        worktree_path="$ADAM_ROOT/worktrees/$CURRENT_AGENT-$TASK"
        git_in "$ADAM_ROOT" fetch
        git_in "$ADAM_ROOT" worktree add "$worktree_path" -b "$branch"
        git_in "$worktree_path" submodule update --init --recursive
    else
        local sub_repo="$ADAM_ROOT/$SCOPE"
        worktree_path="$sub_repo/$SCOPE-worktrees/$CURRENT_AGENT-$TASK"
        git_in "$sub_repo" fetch
        git_in "$sub_repo" worktree add "$worktree_path" -b "$branch" origin/main
    fi

    write_lock "$SCOPE" "$TASK" "$branch" "$worktree_path" "$paths_json"

    echo "claimed: $SCOPE/$TASK"
    echo "  agent:    $CURRENT_AGENT"
    echo "  branch:   $branch"
    echo "  worktree: $worktree_path"
    echo "  cd $worktree_path"
}

cmd_release() {
    [[ $# -ge 1 ]] || die "release: missing <scope>/<task>"
    parse_scope_task "$1"
    shift
    local keep_branch=0
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --keep-branch) keep_branch=1; shift ;;
            --force) force=1; shift ;;
            *) die "unknown flag '$1'" ;;
        esac
    done
    local lock_file
    lock_file="$(lock_path "$SCOPE" "$TASK")"
    [[ -e "$lock_file" ]] || die "no lockfile at $lock_file"

    local worktree branch
    worktree="$(grep -E '"worktree"' "$lock_file" | sed -E 's/.*"worktree" *: *"([^"]+)".*/\1/')"
    branch="$(grep -E '"branch"' "$lock_file" | sed -E 's/.*"branch" *: *"([^"]+)".*/\1/')"

    # Check for dirty changes.
    if [[ -d "$worktree" ]]; then
        if ! git_in "$worktree" diff --quiet || ! git_in "$worktree" diff --cached --quiet; then
            if [[ "$force" -ne 1 ]]; then
                die "worktree $worktree has uncommitted changes (use --force to discard)"
            fi
        fi
    fi

    # Remove the worktree.
    if [[ "$SCOPE" == "cross" ]]; then
        git_in "$ADAM_ROOT" worktree remove "$worktree" ${force:+--force}
    elif [[ -d "$worktree" ]]; then
        git_in "$ADAM_ROOT/$SCOPE" worktree remove "$worktree" ${force:+--force}
    fi

    # Delete branch unless asked to keep.
    if [[ "$keep_branch" -ne 1 ]]; then
        local repo
        if [[ "$SCOPE" == "cross" ]]; then repo="$ADAM_ROOT"; else repo="$ADAM_ROOT/$SCOPE"; fi
        # The branch may have already been pushed + merged; --delete will
        # only refuse if it's not merged. Use -D when --force.
        if [[ "$force" -eq 1 ]]; then
            git_in "$repo" branch -D "$branch" 2>/dev/null || true
        else
            git_in "$repo" branch --delete "$branch" 2>/dev/null || \
                echo "adam: branch $branch not deleted (not merged?); pass --force to drop anyway"
        fi
    fi

    rm "$lock_file"
    echo "released: $SCOPE/$TASK"
}

cmd_status() {
    local show_conflicts=0
    [[ "${1:-}" == "--conflicts" ]] && show_conflicts=1
    shopt -s nullglob
    local locks=("$LOCK_DIR"/*.json)
    shopt -u nullglob
    if [[ ${#locks[@]} -eq 0 ]]; then
        echo "no active claims"
        return 0
    fi
    printf "%-12s %-20s %-30s %s\n" "AGENT" "SCOPE/TASK" "BRANCH" "STARTED"
    for f in "${locks[@]}"; do
        local agent scope task branch started
        agent="$(grep -E '"agent"' "$f" | sed -E 's/.*"agent" *: *"([^"]+)".*/\1/')"
        scope="$(grep -E '"scope"' "$f" | sed -E 's/.*"scope" *: *"([^"]+)".*/\1/')"
        task="$(grep -E '"task"' "$f" | sed -E 's/.*"task" *: *"([^"]+)".*/\1/')"
        branch="$(grep -E '"branch"' "$f" | sed -E 's/.*"branch" *: *"([^"]+)".*/\1/')"
        started="$(grep -E '"started_at"' "$f" | sed -E 's/.*"started_at" *: *"([^"]+)".*/\1/')"
        printf "%-12s %-20s %-30s %s\n" "$agent" "$scope/$task" "$branch" "$started"
    done

    if [[ "$show_conflicts" -eq 1 ]]; then
        echo
        echo "(path-overlap detection not implemented yet — Phase 5 follow-up)"
    fi
}

cmd_sync_hooks() {
    [[ -d "$HOOKS_DIR" ]] || die "no $HOOKS_DIR — was the umbrella bootstrapped correctly?"
    local installed=0
    # Umbrella's own hooks.
    install_hooks_into "$ADAM_ROOT"
    installed=$((installed + 1))
    # Each submodule's hooks (path is .git file -> ../.git/modules/<sub>/).
    for sub in "${SUBMODULES[@]}"; do
        [[ -e "$ADAM_ROOT/$sub/.git" ]] || continue
        install_hooks_into "$ADAM_ROOT/$sub"
        installed=$((installed + 1))
    done
    echo "synced hooks into $installed checkouts"
}

install_hooks_into() {
    local dir="$1"
    # Resolve the actual git-dir (in submodules, .git is a file pointing
    # at ../.git/modules/<sub>/).
    local gitdir
    gitdir="$(git -C "$dir" rev-parse --git-dir)"
    if [[ "$gitdir" != /* ]]; then
        gitdir="$dir/$gitdir"
    fi
    mkdir -p "$gitdir/hooks"
    for h in pre-commit pre-push commit-msg; do
        [[ -f "$HOOKS_DIR/$h" ]] || continue
        cp "$HOOKS_DIR/$h" "$gitdir/hooks/$h"
        chmod +x "$gitdir/hooks/$h"
    done
    # Override any global core.hooksPath that would otherwise hide our
    # installed hooks. Users commonly set core.hooksPath in ~/.config/git
    # for their own dotfiles; without this local override our hooks would
    # never run (and the branch-enforcement guard would be silently
    # disabled). Submodule hooks live under the umbrella's
    # .git/modules/<sub>/hooks — point there explicitly.
    git -C "$dir" config core.hooksPath "$gitdir/hooks"
}

cmd_deploy() {
    [[ $# -ge 1 ]] || die "deploy: missing <host>"
    local host="$1"
    local up="$DEPLOY_DIR/$host/up.sh"
    [[ -x "$up" ]] || die "no executable $up"
    exec "$up"
}

cmd_bump() {
    [[ $# -ge 1 ]] || die "bump: missing <sub-repo>"
    local sub="$1"
    [[ -d "$ADAM_ROOT/$sub" ]] || die "no submodule '$sub' in umbrella"
    git_in "$ADAM_ROOT/$sub" fetch origin main
    git_in "$ADAM_ROOT/$sub" checkout origin/main
    local new_sha
    new_sha="$(git_in "$ADAM_ROOT/$sub" rev-parse HEAD)"
    git_in "$ADAM_ROOT" add "$sub"
    # ADAM_BUMP=1 tells pre-commit to allow this main-branch commit; without
    # it the hook rejects all direct main commits to force agents through
    # the bin/adam claim flow.
    ADAM_BUMP=1 git_in "$ADAM_ROOT" commit -m "bump $sub to $new_sha" || \
        echo "adam: no pin change for $sub (already at $new_sha)"
}

cmd_pin() {
    [[ $# -ge 1 ]] || die "pin: missing <sub-repo>"
    local sub="$1"
    git_in "$ADAM_ROOT" ls-tree HEAD "$sub" | awk '{print $3}'
}

cmd_pull() {
    git_in "$ADAM_ROOT" pull
    git_in "$ADAM_ROOT" submodule update --recursive --remote
}

# ---- doctor / build / test / clean / rescue -----------------------------

cmd_doctor() {
    local ok=1
    echo "==> Adamaton environment check"

    # 1. git config
    local name email
    name="$(git config user.name 2>/dev/null || true)"
    email="$(git config user.email 2>/dev/null || true)"
    if [[ -z "$name" || -z "$email" ]]; then
        echo "  [FAIL] git user.name/email not set"; ok=0
    else
        echo "  [ ok ] git config: $name <$email>"
    fi

    # 2. gh CLI + auth
    if ! command -v gh >/dev/null 2>&1; then
        echo "  [FAIL] gh CLI not installed"; ok=0
    elif ! gh auth status >/dev/null 2>&1; then
        echo "  [FAIL] gh not authenticated"; ok=0
    else
        echo "  [ ok ] gh authenticated"
    fi

    # 3. Go version
    if ! command -v go >/dev/null 2>&1; then
        echo "  [FAIL] go not installed"; ok=0
    else
        local gv
        gv="$(go version | awk '{print $3}')"
        echo "  [ ok ] $gv"
    fi

    # 4. Submodules initialized
    local uninit=0
    for sub in "${SUBMODULES[@]}"; do
        if [[ ! -d "$ADAM_ROOT/$sub/.git" && ! -f "$ADAM_ROOT/$sub/.git" ]]; then
            echo "  [FAIL] submodule '$sub' not initialized"; uninit=$((uninit+1)); ok=0
        fi
    done
    [[ "$uninit" -eq 0 ]] && echo "  [ ok ] all 7 submodules initialized"

    # 5. Hooks installed
    local hook_check
    hook_check="$(git -C "$ADAM_ROOT" rev-parse --git-dir)/hooks/pre-commit"
    if [[ -x "$hook_check" ]]; then
        echo "  [ ok ] umbrella hooks installed"
    else
        echo "  [WARN] umbrella hooks not installed — run: bin/adam sync-hooks"; ok=0
    fi

    # 6. Branch state (warn if on main with uncommitted changes in canonical checkout)
    local top branch dirty
    top="$(git -C "$ADAM_ROOT" rev-parse --show-toplevel)"
    branch="$(git -C "$ADAM_ROOT" symbolic-ref --short -q HEAD 2>/dev/null || echo HEAD)"
    dirty="$(git -C "$ADAM_ROOT" status --porcelain 2>/dev/null | head -1)"
    case "$top" in
        *-worktrees/*|*/worktrees/*) ;;
        *)
            if [[ "$branch" == "main" || "$branch" == "master" ]] && [[ -n "$dirty" ]]; then
                echo "  [WARN] you have uncommitted changes on '$branch' in the canonical checkout."
                echo "         pre-commit will reject these. Run: bin/adam rescue"
                ok=0
            fi
            ;;
    esac

    # 7. Umbrella pin freshness
    if git -C "$ADAM_ROOT" submodule status | grep -qE "^[+]"; then
        echo "  [WARN] one or more submodule pins are out of sync (run: bin/adam pull or bin/adam bump <sub>)"
    fi

    echo
    if [[ "$ok" -eq 1 ]]; then
        echo "✓ doctor: all green"
    else
        echo "✗ doctor: see warnings above"
        return 1
    fi
}

# Mapping of host -> components shipped on that host. Used by `bin/adam build`.
host_components() {
    case "$1" in
        pi5)         echo "skills-rae r2g reindex nano-research dashboard plugin-host dispatch evolve frontend reranker figure-renderer" ;;
        pi5-speaker) echo "nano-research figure-renderer" ;;
        blackwell)   echo "evo-worker-kernel" ;;
        workstation) echo "" ;;
        *) die "unknown host: $1 (valid: pi5 | pi5-speaker | blackwell | workstation)" ;;
    esac
}

cmd_build() {
    [[ $# -ge 1 ]] || die "build: missing <host>"
    local host="$1"
    local tag="${IMAGE_TAG:-$(git_in "$ADAM_ROOT" rev-parse --short HEAD)}"
    local comps; comps="$(host_components "$host")"
    if [[ -z "$comps" ]]; then
        echo "build: no components ship on $host (workstation runs no workers)"
        return 0
    fi
    echo "==> building images for $host at tag $tag"
    echo "   (delegates to Makefile pi-* targets; assumes you've run 'make pi-<comp>' OR run them here)"
    local c
    for c in $comps; do
        echo "  - $c -> adamaton-$c:$tag (pending Makefile target)"
    done
    echo
    echo "NOTE: bin/adam build is a stub. Run the Makefile targets directly for now:"
    echo "   make -C $ADAM_ROOT pi-$comps"
    echo "Then tag built images:"
    for c in $comps; do
        echo "   docker tag adamaton-$c:dev adamaton-$c:$tag"
    done
    echo "The future fleshing-out chains these automatically per host."
}

cmd_test() {
    local scope=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scope=*) scope="${1#--scope=}"; shift ;;
            *) die "unknown flag '$1'" ;;
        esac
    done
    local subs="${SUBMODULES[*]}"
    [[ -n "$scope" ]] && subs="$scope"
    local total_pass=0 total_fail=0
    for sub in $subs; do
        [[ -d "$ADAM_ROOT/$sub" ]] || continue
        # Find go modules under this sub-repo
        local gomods
        gomods="$(find "$ADAM_ROOT/$sub" -name 'go.mod' -not -path '*/node_modules/*' 2>/dev/null)"
        [[ -z "$gomods" ]] && continue
        for gomod in $gomods; do
            local dir; dir="$(dirname "$gomod")"
            printf "  %-40s " "${dir#$ADAM_ROOT/}"
            if (cd "$dir" && GOGENTS_SKIP_DOCKER_TESTS=1 go test -count=1 -timeout 60s ./... >/dev/null 2>&1); then
                echo "PASS"; total_pass=$((total_pass+1))
            else
                echo "FAIL"; total_fail=$((total_fail+1))
            fi
        done
    done
    echo
    echo "totals: $total_pass pass, $total_fail fail"
    [[ "$total_fail" -eq 0 ]]
}

cmd_clean() {
    local force=0
    [[ "${1:-}" == "--force" ]] && force=1
    echo "==> stale-worktree audit"
    local stale=()
    # Each lockfile's worktree; flag if absent on disk OR >7 days old.
    shopt -s nullglob
    for lock in "$LOCK_DIR"/*.json; do
        local wt started
        wt="$(grep -E '"worktree"' "$lock" | sed -E 's/.*"worktree" *: *"([^"]+)".*/\1/')"
        started="$(grep -E '"started_at"' "$lock" | sed -E 's/.*"started_at" *: *"([^"]+)".*/\1/')"
        if [[ ! -d "$wt" ]]; then
            echo "  STALE (no worktree on disk): $lock"
            stale+=("$lock")
            continue
        fi
        # 7-day age check
        if [[ -n "$started" ]]; then
            local age_days
            age_days=$(( ( $(date +%s) - $(date -d "$started" +%s 2>/dev/null || echo $(date +%s)) ) / 86400 ))
            if [[ "$age_days" -gt 7 ]]; then
                echo "  AGED (>${age_days}d, no recent activity): $lock"
                stale+=("$lock")
            fi
        fi
    done
    shopt -u nullglob
    if [[ ${#stale[@]} -eq 0 ]]; then
        echo "  no stale claims"
        return 0
    fi
    if [[ "$force" -eq 1 ]]; then
        echo "  --force: removing ${#stale[@]} stale lockfile(s)..."
        rm -f "${stale[@]}"
    else
        echo
        echo "Re-run with --force to delete the listed lockfiles."
    fi
}

cmd_rescue() {
    local top branch dirty
    top="$(git -C "$ADAM_ROOT" rev-parse --show-toplevel)"
    branch="$(git -C "$ADAM_ROOT" symbolic-ref --short -q HEAD 2>/dev/null || echo HEAD)"
    dirty="$(git -C "$ADAM_ROOT" status --porcelain 2>/dev/null)"

    case "$top" in
        *-worktrees/*|*/worktrees/*)
            echo "rescue: you're already in a worktree ($top). Nothing to do."
            return 0
            ;;
    esac

    if [[ "$branch" != "main" && "$branch" != "master" ]]; then
        echo "rescue: current branch is '$branch' (not main). Nothing to do."
        return 0
    fi

    if [[ -z "$dirty" ]]; then
        echo "rescue: working tree clean. Nothing to do."
        return 0
    fi

    echo "==> RESCUE: uncommitted changes on '$branch' in canonical checkout"
    echo
    echo "Changed files:"
    echo "$dirty" | sed 's/^/  /'
    echo
    echo "Recommended recovery:"
    echo "  1. Stash your changes:        git stash push -m 'rescue from main'"
    echo "  2. Claim a feature branch:    bin/adam claim <scope>/<task>"
    echo "  3. cd into the new worktree (path printed by claim)"
    echo "  4. Apply your stash:          git stash pop"
    echo "  5. Commit + push as usual"
    echo
    echo "Run with --auto to do steps 1-2 automatically (you still need to cd + stash pop)."
}

# ---- ci: local CI runner ---------------------------------------------------
# GitHub Actions is BANNED (operator decision 2026-07-06): no .github/workflows
# files, no hosted runners, no registered self-hosted runners. `adam ci` is the
# canonical CI — it runs the same gates locally, against a throwaway worktree
# of the target at a chosen ref, so the canonical checkout is never touched.
#
# Env knobs:
#   ZTOK_PREFIX  path to a built ztok prefix (include/ + lib/ with libztok).
#                When unset, the cgo modules knowledge/r2g and knowledge/reindex
#                are SKIPped (they cannot build without libztok). When set,
#                they run with CGO_CFLAGS=-I$ZTOK_PREFIX/include and
#                CGO_LDFLAGS=-L$ZTOK_PREFIX/lib.

CI_RESULTS=()      # rows of "STATUS<TAB>target<TAB>step"
CI_LOG_DIR=""      # per-run step logs (path printed at the end)

# Go modules (as <sub-repo>/<dir>) that need libztok via cgo.
CI_ZTOK_MODULES="knowledge/r2g knowledge/reindex"

ci_record() {
    local st="$1" tgt="$2" step="$3"
    CI_RESULTS+=("$st"$'\t'"$tgt"$'\t'"$step")
    local c="" r=""
    if [[ -t 1 ]]; then
        r=$'\033[0m'
        case "$st" in
            PASS) c=$'\033[32m' ;;
            FAIL) c=$'\033[31m' ;;
            *)    c=$'\033[33m' ;;
        esac
    fi
    printf '  %s%-4s%s %s :: %s\n' "$c" "$st" "$r" "$tgt" "$step"
}

# ci_run_step <target> <step-label> <workdir> <cmd...>
# Runs <cmd> in <workdir>, logging to CI_LOG_DIR; on failure prints the log
# tail and records FAIL. Never aborts the whole run (caller aggregates).
ci_run_step() {
    local tgt="$1" step="$2" dir="$3"; shift 3
    local log
    log="$CI_LOG_DIR/$(echo "$tgt-$step" | tr -c 'A-Za-z0-9._-' '_').log"
    if (cd "$dir" && "$@") >"$log" 2>&1; then
        ci_record PASS "$tgt" "$step"
        return 0
    fi
    ci_record FAIL "$tgt" "$step"
    echo "  ---- tail of $log ----"
    tail -n 40 "$log" | sed 's/^/  | /'
    return 1
}

# ci_sub <sub-repo> [ref]: check out <ref> (default origin/main) of the
# sub-repo in a TEMP git worktree under /tmp, inside a synthetic sibling
# layout — every other sub-repo is a symlink to its canonical checkout — so
# `replace ../../core`-style go.mod paths resolve without go.work.
ci_sub() {
    local repo="$1" ref="${2:-}"
    local src="$ADAM_ROOT/$repo"
    if [[ ! -e "$src/.git" ]]; then
        ci_record SKIP "$repo" "submodule not initialized at $src"
        return 0
    fi
    echo "==> ci: $repo"
    git_in "$src" fetch origin --quiet 2>/dev/null || \
        echo "adam: warning: git fetch failed for $repo (offline?); using local refs" >&2
    [[ -z "$ref" ]] && ref="origin/main"
    if ! git_in "$src" rev-parse --verify --quiet "$ref^{commit}" >/dev/null; then
        ci_record FAIL "$repo" "resolve ref '$ref'"
        return 1
    fi

    local tmp tree
    tmp="$(mktemp -d "${TMPDIR:-/tmp}/adam-ci-$repo.XXXXXX")"
    tree="$tmp/tree"
    mkdir -p "$tree"
    local s
    for s in "${SUBMODULES[@]}"; do
        [[ "$s" == "$repo" ]] && continue
        [[ -d "$ADAM_ROOT/$s" ]] && ln -s "$ADAM_ROOT/$s" "$tree/$s"
    done
    if ! git_in "$src" worktree add --detach --force "$tree/$repo" "$ref" >/dev/null 2>&1; then
        ci_record FAIL "$repo" "git worktree add @ $ref"
        rm -rf "$tmp"
        return 1
    fi
    # Nested submodules (e.g. core/contracts/lib/forge-std) are not populated
    # by `worktree add`; tests that shell out to them fail spuriously without
    # this. Non-fatal: offline runs still get the go gates.
    git_in "$tree/$repo" submodule update --init --recursive --depth 1 >/dev/null 2>&1 || \
        echo "adam: warning: nested submodule init failed for $repo (offline?)" >&2
    echo "    ref: $ref ($(git_in "$src" rev-parse --short "$ref")); tree: $tree/$repo"

    local rc=0
    if [[ "$repo" == "frontend" ]]; then
        ci_frontend "$tree/$repo" || rc=1
    else
        ci_go_repo "$repo" "$tree/$repo" || rc=1
    fi

    git_in "$src" worktree remove --force "$tree/$repo" >/dev/null 2>&1 || true
    git_in "$src" worktree prune >/dev/null 2>&1 || true
    rm -rf "$tmp"
    return $rc
}

# ci_go_repo <sub-repo> <tree-root>: vet + build + test every go.mod module.
ci_go_repo() {
    local repo="$1" root="$2"
    local mods
    mods="$(cd "$root" && find . -name go.mod \
        -not -path '*/node_modules/*' -not -path '*-worktrees/*' \
        -printf '%h\n' | sort)"
    if [[ -z "$mods" ]]; then
        ci_record SKIP "$repo" "no go modules"
        return 0
    fi
    local rc=0 rel mod label moddir id
    for rel in $mods; do
        mod="${rel#./}"
        label="${mod:-.}"
        moddir="$root${mod:+/$mod}"
        id="$repo${mod:+/$mod}"
        case " $CI_ZTOK_MODULES " in
            *" $id "*)
                if [[ -z "${ZTOK_PREFIX:-}" ]]; then
                    ci_record SKIP "$repo" "$label (needs libztok; set ZTOK_PREFIX to run)"
                    continue
                fi
                ;;
        esac
        local -a envv=(GOWORK=off GOGENTS_SKIP_DOCKER_TESTS=1)
        if [[ -n "${ZTOK_PREFIX:-}" ]]; then
            envv+=("CGO_CFLAGS=-I$ZTOK_PREFIX/include" "CGO_LDFLAGS=-L$ZTOK_PREFIX/lib")
        fi
        ci_run_step "$repo" "$label go vet"   "$moddir" env "${envv[@]}" go vet ./...   || rc=1
        ci_run_step "$repo" "$label go build" "$moddir" env "${envv[@]}" go build ./... || rc=1
        ci_run_step "$repo" "$label go test"  "$moddir" env "${envv[@]}" go test ./...  || rc=1
    done
    return $rc
}

# ci_frontend <tree-root>: pnpm install (frozen once pnpm-lock.yaml is
# committed — auto-detected) + vite prod build.
ci_frontend() {
    local root="$1" rc=0
    if ! command -v pnpm >/dev/null 2>&1; then
        ci_record SKIP frontend "pnpm not installed"
        return 0
    fi
    if [[ -f "$root/pnpm-lock.yaml" ]]; then
        ci_run_step frontend "pnpm install --frozen-lockfile" "$root" \
            pnpm install --frozen-lockfile || rc=1
    else
        ci_run_step frontend "pnpm install (no pnpm-lock.yaml committed yet)" "$root" \
            pnpm install || rc=1
    fi
    if [[ -x "$root/node_modules/.bin/vite" ]]; then
        # pnpm v11's verify-deps can trip `pnpm <script>`; call vite directly.
        ci_run_step frontend "vite build" "$root" ./node_modules/.bin/vite build || rc=1
    else
        ci_record FAIL frontend "vite build (node_modules/.bin/vite missing after install)"
        rc=1
    fi
    return $rc
}

# ci_cross: validate the umbrella's deploy configs as checked out here.
# Catches the exact class of bug that broke a pi5 deploy on 2026-07-06
# (duplicate compose healthcheck key — invisible to yaml.safe_load, which
# silently keeps the last duplicate; the strict parser rejects it).
ci_cross() {
    echo "==> ci: cross (umbrella deploy configs)"
    local rc=0 f host
    for f in "$DEPLOY_DIR"/*/docker-compose.yml; do
        [[ -f "$f" ]] || continue
        host="$(basename "$(dirname "$f")")"
        ci_compose_yaml_strict "$host" "$f" || rc=1
        ci_compose_config "$host" "$f" || rc=1
    done
    local caddyfile="$DEPLOY_DIR/pi5/Caddyfile"
    if [[ -f "$caddyfile" ]]; then
        if command -v docker >/dev/null 2>&1; then
            ci_run_step cross "caddy validate (pi5/Caddyfile)" "$DEPLOY_DIR/pi5" \
                docker run --rm -v "$DEPLOY_DIR/pi5:/w:ro" caddy:2-alpine \
                caddy validate --adapter caddyfile --config /w/Caddyfile || rc=1
        else
            ci_record SKIP cross "caddy validate (docker not available)"
        fi
    fi
    for f in "$DEPLOY_DIR"/*/MANIFEST.yaml; do
        [[ -f "$f" ]] || continue
        host="$(basename "$(dirname "$f")")"
        if manifest_validate "$f"; then
            ci_record PASS cross "MANIFEST.yaml schema ($host)"
        else
            ci_record FAIL cross "MANIFEST.yaml schema ($host)"
            rc=1
        fi
    done
    return $rc
}

# Strict YAML parse: rejects duplicate mapping keys anywhere in the file
# (yaml.safe_load and docker compose both silently last-write-wins them).
ci_compose_yaml_strict() {
    local host="$1" f="$2" out
    if out="$(python3 - "$f" <<'PYEOF' 2>&1
import sys, yaml

class StrictLoader(yaml.SafeLoader):
    pass

def _mapping(loader, node, deep=False):
    seen = {}
    for k_node, _ in node.value:
        key = loader.construct_object(k_node, deep=deep)
        if key in seen:
            raise yaml.YAMLError(
                "duplicate key %r (lines %d and %d)"
                % (key, seen[key], k_node.start_mark.line + 1))
        seen[key] = k_node.start_mark.line + 1
    return yaml.SafeLoader.construct_mapping(loader, node, deep=deep)

StrictLoader.add_constructor(
    yaml.resolver.BaseResolver.DEFAULT_MAPPING_TAG, _mapping)

with open(sys.argv[1]) as fh:
    yaml.load(fh, Loader=StrictLoader)
PYEOF
)"; then
        ci_record PASS cross "yaml strict-parse ($host/docker-compose.yml)"
        return 0
    fi
    ci_record FAIL cross "yaml strict-parse ($host/docker-compose.yml)"
    echo "$out" | sed 's/^/  | /'
    return 1
}

# Full compose validation via `docker compose config -q`, run from a temp
# copy with stub .env / image-tags.env and stub values for every ${VAR} that
# has no default — so the file must interpolate + validate without the
# host's real secrets.
ci_compose_config() {
    local host="$1" f="$2"
    if ! command -v docker >/dev/null 2>&1; then
        ci_record SKIP cross "compose config -q ($host) — docker not available"
        return 0
    fi
    local tmp v out
    tmp="$(mktemp -d "${TMPDIR:-/tmp}/adam-ci-compose.XXXXXX")"
    cp "$f" "$tmp/docker-compose.yml"
    touch "$tmp/.env" "$tmp/image-tags.env"
    # Vars written as ${VAR}, ${VAR?...} or ${VAR:?...} have no default and
    # must be stubbed; anything with :- keeps its in-file default.
    while read -r v; do
        [[ -z "$v" ]] && continue
        case "$v" in
            *IP*|*HOST*) echo "$v=127.0.0.1" ;;
            *)           echo "$v=ci-stub" ;;
        esac
    done < <(grep -ohE '\$\{[A-Za-z_][A-Za-z0-9_]*(\}|:?\?)' "$f" \
             | sed -E 's/^\$\{//; s/[:?}]+$//' | sort -u) > "$tmp/ci-stub.env"
    if out="$(docker compose --project-name adam-ci --env-file "$tmp/ci-stub.env" \
              --project-directory "$tmp" -f "$tmp/docker-compose.yml" config -q 2>&1)"; then
        ci_record PASS cross "compose config -q ($host)"
        rm -rf "$tmp"
        return 0
    fi
    ci_record FAIL cross "compose config -q ($host)"
    echo "$out" | sed 's/^/  | /'
    rm -rf "$tmp"
    return 1
}

# manifest_validate <MANIFEST.yaml>: schema-check a host manifest and
# cross-check its service allow-list against the sibling docker-compose.yml.
# Schema problems → return 1. Services listed in the MANIFEST but absent
# from compose are a WARNING only: pi5 intentionally keeps retired workers
# allow-listed through their rollback window.
manifest_validate() {
    local m="$1"
    python3 - "$m" "$(dirname "$m")/docker-compose.yml" <<'PYEOF'
import os, sys, yaml
mpath, cpath = sys.argv[1], sys.argv[2]
errs, warns = [], []
try:
    m = yaml.safe_load(open(mpath))
except yaml.YAMLError as e:
    print("  ERROR %s: YAML parse error: %s" % (mpath, e), file=sys.stderr)
    sys.exit(1)
if not isinstance(m, dict):
    print("  ERROR %s: top level must be a mapping" % mpath, file=sys.stderr)
    sys.exit(1)

host = m.get("host")
if not isinstance(host, str) or not host:
    errs.append("missing/invalid 'host' (non-empty string required)")
else:
    dirname = os.path.basename(os.path.dirname(os.path.abspath(mpath)))
    if host != dirname:
        errs.append("'host: %s' does not match directory '%s'" % (host, dirname))

tag = m.get("image_tag")
if not isinstance(tag, str) or not tag.strip():
    errs.append("missing/invalid 'image_tag' (non-empty string required)")

svcs = m.get("services")
if not isinstance(svcs, list) or not svcs or \
        not all(isinstance(s, str) and s for s in svcs):
    errs.append("missing/invalid 'services' (non-empty list of strings required)")
else:
    dupes = sorted({s for s in svcs if svcs.count(s) > 1})
    if dupes:
        errs.append("duplicate services: " + ", ".join(dupes))
    if os.path.exists(cpath):
        try:
            comp = yaml.safe_load(open(cpath)) or {}
            comp_svcs = set((comp.get("services") or {}).keys())
            missing = sorted(set(svcs) - comp_svcs)
            if missing:
                warns.append("services in MANIFEST but not in docker-compose.yml "
                             "(ok if retained for a rollback window): "
                             + ", ".join(missing))
        except yaml.YAMLError as e:
            warns.append("could not cross-check compose file: %s" % e)
    else:
        warns.append("no docker-compose.yml beside MANIFEST; service cross-check skipped")

for w in warns:
    print("  WARN  %s: %s" % (mpath, w), file=sys.stderr)
for e in errs:
    print("  ERROR %s: %s" % (mpath, e), file=sys.stderr)
sys.exit(1 if errs else 0)
PYEOF
}

ci_summary() {
    echo
    echo "==> ci summary"
    printf '  %-6s %-12s %s\n' RESULT TARGET STEP
    printf '  %-6s %-12s %s\n' ------ ------------ ----
    local row st tgt step fails=0 passes=0 skips=0
    for row in "${CI_RESULTS[@]}"; do
        IFS=$'\t' read -r st tgt step <<< "$row"
        printf '  %-6s %-12s %s\n' "$st" "$tgt" "$step"
        case "$st" in
            FAIL) fails=$((fails+1)) ;;
            PASS) passes=$((passes+1)) ;;
            *)    skips=$((skips+1)) ;;
        esac
    done
    echo
    echo "  totals: $passes pass, $fails fail, $skips skip"
    echo "  step logs: $CI_LOG_DIR"
    [[ "$fails" -eq 0 ]]
}

cmd_ci() {
    [[ $# -ge 1 ]] || die "ci: usage: adam ci <target> [ref]   (target = ${SUBMODULES[*]} | cross | all)"
    local target="$1" ref="${2:-}"
    command -v python3 >/dev/null 2>&1 || die "ci: python3 (with PyYAML) is required"
    CI_RESULTS=()
    CI_LOG_DIR="$(mktemp -d "${TMPDIR:-/tmp}/adam-ci-logs.XXXXXX")"
    local rc=0 s
    case "$target" in
        all)
            [[ -n "$ref" ]] && die "ci all: [ref] not supported (each target uses its own origin/main)"
            for s in "${SUBMODULES[@]}"; do
                ci_sub "$s" "" || rc=1      # no fail-fast: run everything, aggregate
            done
            ci_cross || rc=1
            ;;
        cross)
            [[ -n "$ref" ]] && die "ci cross: [ref] not supported; validates the current umbrella checkout"
            ci_cross || rc=1
            ;;
        *)
            local ok=0
            for s in "${SUBMODULES[@]}"; do [[ "$s" == "$target" ]] && ok=1; done
            [[ "$ok" -eq 1 ]] || die "ci: unknown target '$target' (valid: ${SUBMODULES[*]} cross all)"
            ci_sub "$target" "$ref" || rc=1
            ;;
    esac
    ci_summary || rc=1
    return $rc
}

# ---- fleet: multi-host pull/promote/status -------------------------------

cmd_fleet() {
    local sub="${1:-status}"; shift || true
    case "$sub" in
        status)  fleet_status "$@" ;;
        verify)  fleet_verify "$@" ;;
        pull)    fleet_pull "$@" ;;
        promote) fleet_promote "$@" ;;
        *) die "unknown fleet subcommand '$sub' (valid: status | verify | pull | promote)" ;;
    esac
}

# fleet_verify <host|all>: post-deploy smoke test. For each service in the
# host's deploy-agent MANIFEST, ask the agent for its `docker compose ps`
# state + health + running image, and print a red/green table. Exits non-zero
# if any service is not running/healthy (or the agent is unreachable) so it
# can gate a ship postflight or a scheduled alert. Pure HTTP via the
# deploy-agent — no ssh — so it works uniformly on pi5 and the localhost-only
# blackwell agent. Card-ec3d258a.
fleet_verify() {
    local host="" notify=0 a
    for a in "$@"; do
        case "$a" in
            --notify) notify=1 ;;
            -*) die "fleet verify: unknown flag '$a'" ;;
            *) host="$a" ;;
        esac
    done
    [[ -z "$host" ]] && die "fleet verify: usage: adam fleet verify <host|all> [--notify]"
    load_ship_env
    local rc=0 red=""
    local hosts=("$host")
    [[ "$host" == "all" ]] && hosts=(pi5 pi5-speaker blackwell)
    for h in "${hosts[@]}"; do
        fleet_verify_one "$h" || { rc=1; red="$red $h"; }
    done
    # --notify: POST an ntfy/webhook alert when a topology-required service is
    # red. Bounded by the caller's schedule (e.g. the systemd timer interval);
    # re-alerts each run while red (no transition de-dup yet — see card).
    if (( notify )) && [[ -n "$red" ]]; then
        fleet_notify "$red"
    fi
    return $rc
}

# fleet_notify <red-hosts>: POST a fleet-red alert to $ADAMATON_ALERT_WEBHOOK
# (set it in ~/.adamaton/ship.env). ntfy-compatible: the POST body is the
# message; Title/Priority/Tags headers are honored by ntfy and harmless to a
# generic webhook. No-op (with a warning) when the webhook URL is unset.
fleet_notify() {
    local red="$1" url="${ADAMATON_ALERT_WEBHOOK:-}"
    if [[ -z "$url" ]]; then
        echo "adam: --notify set but ADAMATON_ALERT_WEBHOOK is empty (add it to ~/.adamaton/ship.env); no alert sent" >&2
        return 0
    fi
    local msg="Adamaton fleet RED:${red} — a topology-required service is down/unhealthy. Check: bin/adam fleet verify${red}"
    if curl -fsS -m 10 \
            -H "Title: Adamaton fleet alert" \
            -H "Priority: high" \
            -H "Tags: rotating_light" \
            -d "$msg" "$url" >/dev/null 2>&1; then
        echo "    alert posted to ADAMATON_ALERT_WEBHOOK (red:${red})"
    else
        echo "adam: warning: alert POST to ADAMATON_ALERT_WEBHOOK failed" >&2
    fi
    return 0
}

fleet_verify_one() {
    local host="$1"
    local url auth
    url="$(host_deploy_url "$host")"
    auth="Authorization: Bearer $DEPLOY_AGENT_TOKEN"

    # Colors only on a TTY (a cron/CI run gets plain text it can grep).
    local C_R="" C_G="" C_Y="" C_0=""
    if [[ -t 1 ]]; then C_R=$'\033[31m'; C_G=$'\033[32m'; C_Y=$'\033[33m'; C_0=$'\033[0m'; fi

    echo "==> fleet verify: $host ($url)"

    # Agent liveness first — distinguishes "agent down" from "services down".
    if ! curl -fsS --max-time 5 "$url/health" >/dev/null 2>&1; then
        printf '  %sFAIL%s deploy-agent unreachable at %s\n' "$C_R" "$C_0" "$url"
        return 1
    fi

    local svcs
    if ! svcs="$(curl -fsS --max-time 10 -H "$auth" "$url/services" 2>/dev/null | jq -r '.services[]?' 2>/dev/null)"; then
        printf '  %sFAIL%s could not list services from %s/services (auth/agent error)\n' "$C_R" "$C_0" "$url"
        return 1
    fi
    if [[ -z "$svcs" ]]; then
        echo "  (no services in this host's MANIFEST)"
        return 0
    fi

    # "Expected running" = topology.yml roles with min_healthy>=1 and not
    # optional. This is what gates the exit code: a service the topology says
    # must be up that is absent/unhealthy is RED; a service that's down but NOT
    # in this set (cold workers, profile-gated trainers, retired-but-still-
    # allow-listed entries, optional services like bge-embed/vllm) is a WARN,
    # not a failure — so a scheduled verify doesn't cry wolf on intended-cold.
    # The deploy-agent's `compose ps` (no -a) can't itself tell cold from
    # crashed; topology membership is the opt-in "this must be up" signal.
    local expected=""
    local topo="$DEPLOY_DIR/health/topology.yml"
    if [[ -f "$topo" ]]; then
        expected="$(python3 -c "
import yaml,sys
d=yaml.safe_load(open(sys.argv[1])) or {}
for n,r in (d.get('roles') or {}).items():
    r=r or {}
    if r.get('min_healthy',0)>=1 and not r.get('optional'): print(n)
" "$topo" 2>/dev/null || true)"
    fi

    printf '      %-26s %-9s %-9s %s\n' SERVICE STATE HEALTH IMAGE-TAG
    local any_red=0 warns=0 svc raw first state health image tag mark exp
    while IFS= read -r svc; do
        [[ -z "$svc" ]] && continue
        raw="$(curl -fsS --max-time 25 -H "$auth" "$url/status?service=$svc" 2>/dev/null || true)"
        # Tolerate the shapes `docker compose ps --format json` emits (a JSON
        # array, NDJSON, a single object) plus the agent's {error,output}
        # body; take the first container object.
        first="$(printf '%s' "$raw" | jq -c 'if type=="array" then .[] else . end' 2>/dev/null | head -n1)"
        if [[ -z "$first" ]]; then
            state="absent"; health=""; image=""
        elif printf '%s' "$first" | jq -e 'has("error")' >/dev/null 2>&1; then
            state="error"; health="$(printf '%s' "$first" | jq -r '.error' | head -c 40)"; image=""
        else
            state="$(printf '%s' "$first" | jq -r '.State // "?"')"
            health="$(printf '%s' "$first" | jq -r '.Health // ""')"
            image="$(printf '%s' "$first" | jq -r '.Image // ""')"
        fi
        tag="${image##*:}"; [[ "$tag" == "$image" ]] && tag="${image:+<no-tag>}"
        exp=0; grep -qxF "$svc" <<<"$expected" && exp=1

        if [[ "$state" == "running" ]]; then
            if [[ "$health" == "healthy" || -z "$health" ]]; then
                mark="${C_G}ok  ${C_0}"
            elif [[ "$health" == "starting" ]]; then
                mark="${C_Y}warn${C_0}"; warns=$((warns+1))
            else                                   # unhealthy / anything bad
                mark="${C_R}FAIL${C_0}"; any_red=1
            fi
        else                                       # not running
            if (( exp )); then
                mark="${C_R}FAIL${C_0}"; any_red=1 # topology says it must be up
            else
                mark="${C_Y}cold${C_0}"; warns=$((warns+1))
            fi
        fi
        printf '  %s %-26s %-9s %-9s %s\n' "$mark" "$svc" "$state" "${health:-—}" "${tag:-—}"
    done <<< "$svcs"

    if (( any_red )); then
        printf '  %s→ RED: an expected-running service on %s is not running/healthy%s' "$C_R" "$host" "$C_0"
        (( warns )) && printf ' (%d warn/cold)' "$warns"
        printf '\n'
        return 1
    fi
    if (( warns )); then
        printf '  %s→ green on %s (%d warn/cold — down but not topology-required)%s\n' "$C_G" "$host" "$warns" "$C_0"
    else
        printf '  %s→ all green on %s%s\n' "$C_G" "$host" "$C_0"
    fi
    return 0
}

fleet_status() {
    echo "==> fleet status"
    for host in pi5 pi5-speaker blackwell; do
        local m="$DEPLOY_DIR/$host/MANIFEST.yaml"
        if [[ ! -f "$m" ]]; then
            echo "  $host: no MANIFEST.yaml"
            continue
        fi
        echo "  --- $host ---"
        # Print the manifest's image_tag + service list.
        grep -E "^(image_tag|services|  -)" "$m" | sed 's/^/    /'
    done
}

fleet_pull() {
    local host="${1:-}"
    [[ -z "$host" ]] && die "fleet pull: missing <host> (or 'all')"
    if [[ "$host" == "all" ]]; then
        for h in pi5 pi5-speaker blackwell; do fleet_pull_one "$h"; done
    else
        fleet_pull_one "$host"
    fi
}

fleet_pull_one() {
    local host="$1"
    local m="$DEPLOY_DIR/$host/MANIFEST.yaml"
    [[ -f "$m" ]] || die "no MANIFEST.yaml at $m"
    local tag
    tag="$(grep -E '^image_tag:' "$m" | sed -E 's/^image_tag: *"?([^"]+)"?/\1/')"
    echo "==> pulling on $host: image_tag=$tag"
    ssh "$host" "cd ~/Adamaton-deploy && IMAGE_TAG=$tag docker compose pull && IMAGE_TAG=$tag docker compose up -d && docker compose ps"
}

# fleet promote <sha-or-tag> [--dry-run]: bulk-retag every host MANIFEST.
# Each MANIFEST is validated first (schema + services-vs-compose cross-check
# via manifest_validate); a schema error on ANY host aborts before any file
# is touched. --dry-run prints the would-be edits and changes nothing.
fleet_promote() {
    local tag="" dry=0 a
    for a in "$@"; do
        case "$a" in
            --dry-run) dry=1 ;;
            -*) die "fleet promote: unknown flag '$a'" ;;
            *) tag="$a" ;;
        esac
    done
    [[ -z "$tag" ]] && die "fleet promote: usage: adam fleet promote <sha-or-tag> [--dry-run]"

    # Validate every MANIFEST before mutating any of them.
    local host m bad=0
    for host in pi5 pi5-speaker blackwell; do
        m="$DEPLOY_DIR/$host/MANIFEST.yaml"
        [[ -f "$m" ]] || continue
        manifest_validate "$m" || bad=1
    done
    [[ "$bad" -ne 0 ]] && die "fleet promote: MANIFEST validation failed; fix the errors above before promoting"

    for host in pi5 pi5-speaker blackwell; do
        m="$DEPLOY_DIR/$host/MANIFEST.yaml"
        [[ -f "$m" ]] || continue
        local cur
        cur="$(grep -E '^image_tag:' "$m" | head -1 | sed -E 's/^image_tag:[[:space:]]*//')"
        if (( dry )); then
            echo "  dry-run: $host: image_tag $cur -> \"$tag\""
            continue
        fi
        sed -i -E "s|^image_tag:.*|image_tag: \"$tag\"|" "$m"
        git_in "$ADAM_ROOT" add "$m"
    done
    if (( dry )); then
        echo "  dry-run: no files changed, no commit made"
        return 0
    fi
    ADAM_BUMP=1 git_in "$ADAM_ROOT" commit -m "fleet: promote to $tag" || \
        echo "adam: no manifest change (already at $tag)"
}

# ---- ship: build + push to workstation registry, restart on host --------

# Load DEPLOY_AGENT_TOKEN + WORKSTATION_IP from ~/.adamaton/ship.env. Both
# subcommands need them; missing file points the user at the runbook.
load_ship_env() {
    local env_file="$HOME/.adamaton/ship.env"
    if [[ ! -f "$env_file" ]]; then
        die "missing $env_file — see docs/PUSH_DEPLOY.md for one-time setup (token + WORKSTATION_IP)"
    fi
    # shellcheck disable=SC1090
    source "$env_file"
    [[ -n "${DEPLOY_AGENT_TOKEN:-}" ]] || die "$env_file must set DEPLOY_AGENT_TOKEN"
    [[ -n "${WORKSTATION_IP:-}" ]]     || die "$env_file must set WORKSTATION_IP"
}

# host_ssh_alias <host>: what name to pass to ssh. Honors HOST_SSH_<UPPER>
# from ship.env; falls back to the bare logical name so ~/.ssh/config
# Host stanzas resolve (e.g. `Host pi5\nHostName deepresearch.local`).
host_ssh_alias() {
    local h="$1" key
    key="HOST_SSH_$(echo "$h" | tr 'a-z-' 'A-Z_')"
    echo "${!key:-$h}"
}

# host_https_alias <host>: HTTPS hostname for Caddy. Honors
# HOST_HTTPS_<UPPER> (e.g. HOST_HTTPS_PI5=deepresearch.local), else
# defaults to <host>.local (mDNS convention). Use for curl; never ssh.
host_https_alias() {
    local h="$1" key
    key="HOST_HTTPS_$(echo "$h" | tr 'a-z-' 'A-Z_')"
    echo "${!key:-${h}.local}"
}

# host_deploy_url <host>: base URL for the deploy-agent (no trailing
# slash). Defaults to http://<mdns_alias>:9128 because not every host
# runs Caddy (pi5-speaker doesn't), and the bearer token is already
# the security boundary -- TLS adds no auth value over LAN-internal
# HTTP. Uses host_https_alias (mDNS .local by default, or the
# HOST_HTTPS_<H> override) for the hostname because ssh aliases from
# ~/.ssh/config aren't DNS-resolvable for curl. Override the whole URL
# with HOST_DEPLOY_URL_<UPPER> in ship.env when a host fronts the agent
# through HTTPS (e.g. https://deepresearch.local/deploy).
host_deploy_url() {
    local h="$1" key target
    key="HOST_DEPLOY_URL_$(echo "$h" | tr 'a-z-' 'A-Z_')"
    if [[ -n "${!key:-}" ]]; then
        echo "${!key}"
        return
    fi
    target=$(host_https_alias "$h")
    echo "http://${target}:9128"
}

# host_platform <host>: docker buildx --platform value. Honors
# HOST_PLATFORM_<UPPER> (e.g. HOST_PLATFORM_BLACKWELL=linux/amd64),
# defaults to linux/arm64 (the Pi default). Used by ship + ship-self
# + bootstrap so amd64 hosts don't end up with qemu-emulated arm64
# images.
host_platform() {
    local h="$1" key
    key="HOST_PLATFORM_$(echo "$h" | tr 'a-z-' 'A-Z_')"
    echo "${!key:-linux/arm64}"
}

# ensure_binfmt <platform>: cross-arch buildx needs the qemu binfmt
# handler registered with the kernel. tonistiigi/binfmt registration
# CLEARS ON EVERY REBOOT and the failure mode is a confusing mid-build
# "exec format error" in RUN steps. Idempotent: no-op when the target
# arch is native or the handler is already registered.
ensure_binfmt() {
    local platform="$1"
    [[ "$platform" == *arm64* ]] || return 0
    [[ "$(uname -m)" == "x86_64" ]] || return 0
    [[ -e /proc/sys/fs/binfmt_misc/qemu-aarch64 ]] && return 0
    echo "    binfmt: registering arm64 qemu handler (clears on reboot)"
    docker run --privileged --rm tonistiigi/binfmt --install arm64 >/dev/null \
        || die "binfmt registration failed; run manually: docker run --privileged --rm tonistiigi/binfmt --install arm64"
}

# service -> "<sub_repo>|<dockerfile>|<context>|<image_name>"
# sub_repo is relative to $ADAM_ROOT and identifies which git checkout owns
# the source (used for SHA tag + dirty check). image_name is the registry
# repo name; several services share an image (nano-research-worker reuses
# the nano-research image; evo-api ships the dashboard binary under its own
# compose name; backend/worker-lo share platform-backend).
ship_service_spec() {
    case "$1" in
        # dashboard + evo-api use context=. because dashboard/go.mod has
        # replace directives that reach across to ../../core, ../../knowledge,
        # etc. Multi-stage build needs every sub-repo in the build context.
        dashboard)             echo "platform|platform/dashboard/Dockerfile|.|adamaton-dashboard" ;;
        plugin-host)           echo "platform|platform/plugin-host/Dockerfile|.|adamaton-plugin-host" ;;
        dispatch-worker)       echo "platform|platform/dispatch/Dockerfile|.|adamaton-dispatch-worker" ;;
        deploy-agent)          echo "platform|platform/deploy-agent/Dockerfile|.|adamaton-deploy-agent" ;;
        # bge-embed wraps llama-server + bakes the bge-m3 GGUF in. The
        # build context can be the tiny platform/bge-embed/ dir because
        # the Dockerfile is FROM ggml-org/llama.cpp:server-cuda + ADD —
        # no cross-module Go sources to pull in.
        bge-embed)             echo "platform|platform/bge-embed/Dockerfile|platform/bge-embed|adamaton-bge-embed" ;;
        evo-api)               echo "platform|platform/dashboard/Dockerfile|.|adamaton-evo-api" ;;
        backend)               echo "platform|platform/backend/Dockerfile|platform/backend|adamaton-platform-backend" ;;
        worker-lo)             echo "platform|platform/backend/Dockerfile|platform/backend|adamaton-platform-backend" ;;
        # r2g build context is the UMBRELLA root: since the ztok cgo flip
        # the Dockerfile COPYs both `ztok` and `knowledge/r2g/` as
        # umbrella-relative paths (it cross-builds libztok.a from the ztok
        # source in a Zig stage). ztok is not a submodule — it must be
        # present at the umbrella root for the build context (see
        # adamaton_ztok_local_build_recipe). Context=knowledge fails with
        # "/knowledge/r2g not found".
        r2g)                   echo "knowledge|knowledge/r2g/Dockerfile|.|adamaton-r2g" ;;
        skills-rae)            echo "knowledge|knowledge/skills-rae/Dockerfile|.|adamaton-skills-rae" ;;
        skills-rae-worker)     echo "knowledge|knowledge/skills-rae/Dockerfile|.|adamaton-skills-rae-worker" ;;
        skills-worker)         echo "knowledge|knowledge/skills/Dockerfile|.|adamaton-skills-worker" ;;
        reindex-worker)        echo "knowledge|knowledge/reindex/Dockerfile|.|adamaton-reindex-worker" ;;
        nano-research)         echo "deepresearch|deepresearch/nano-research/Dockerfile|.|adamaton-nano-research" ;;
        nano-research-worker)  echo "deepresearch|deepresearch/nano-research/Dockerfile|.|adamaton-nano-research" ;;
        figure-renderer)       echo "deepresearch|deepresearch/nano-research/sidecars/figure-renderer/Dockerfile|deepresearch/nano-research/sidecars/figure-renderer|adamaton-nano-figure-renderer" ;;
        evo-worker)            echo "evolve|evolve/evolve/Dockerfile|.|adamaton-evo-worker" ;;
        dataset-worker)        echo "evolve|evolve/dataset-manager/Dockerfile|.|adamaton-dataset-worker" ;;
        # v1.0 / v1.1 on-chain observability daemons. Same multi-module
        # build context as dispatch-worker because they pull from
        # core/p2p/eth which (in v1.x) may grow replace directives across
        # the sub-repo boundary. Each daemon reads one core/cmd/* entry-
        # point and otherwise shares the core go.mod.
        audit-monitor)         echo "core|core/cmd/audit-monitor/Dockerfile|.|adamaton-audit-monitor" ;;
        federation-monitor)    echo "core|core/cmd/federation-monitor/Dockerfile|.|adamaton-federation-monitor" ;;
        ledger-monitor)        echo "core|core/cmd/ledger-monitor/Dockerfile|.|adamaton-ledger-monitor" ;;
        finalize-bot)          echo "core|core/cmd/finalize-bot/Dockerfile|.|adamaton-finalize-bot" ;;
        stealthmonitor)        echo "core|core/cmd/stealthmonitor/Dockerfile|.|adamaton-stealthmonitor" ;;
        # Unified build-tag-configurable worker. Three variants share the
        # same Dockerfile + source tree; each variant pins a multi-stage
        # --target and a GO_TAGS build-arg, plus a final field naming
        # the compose service that hosts the image (so deploy-agent
        # restart targets the right service even when ship-spec key !=
        # service name). 7-field spec:
        #   sub_repo|dockerfile|context|image|target|go_tags|compose_service
        adamaton-worker-light) echo "platform|platform/worker/Dockerfile|.|adamaton-worker-light|runtime-light|skills reindex dispatch|adamaton-worker" ;;
        adamaton-worker-full)  echo "platform|platform/worker/Dockerfile|.|adamaton-worker-full|runtime-full|skills reindex dispatch evo|adamaton-worker" ;;
        adamaton-worker-gpu)   echo "platform|platform/worker/Dockerfile|.|adamaton-worker-gpu|runtime-gpu|evo|adamaton-worker" ;;
        *)                     return 1 ;;
    esac
}

# ship_frontend <host>: the frontend is not a registry image — it's a vite
# bundle bind-mounted into the caddy container as ./frontend-dist (see the
# frontend service in deploy/pi5/docker-compose.yml). Build it from the
# frontend submodule, refresh deploy/pi5/frontend-dist/ (the source of truth
# a full `adam deploy` rsyncs), push it to the host, and restart the caddy
# container — required even for a directory bind-mount because rsync renames
# files in place and caddy keeps serving the old inodes (docs/PUSH_DEPLOY.md).
ship_frontend() {
    local host="$1"
    local fe="$ADAM_ROOT/frontend"
    local dist="$ADAM_ROOT/deploy/pi5/frontend-dist"
    local ssh_target
    ssh_target=$(host_ssh_alias "$host")
    [[ -f "$fe/package.json" ]] || die "frontend submodule is not checked out"

    echo "==> ship: frontend (vite bundle) -> $host"
    # ALWAYS install (idempotent + fast when up-to-date). Skipping it when
    # node_modules merely exists builds against STALE modules after a
    # dependency change — e.g. a dependabot bump or a newly-declared dep
    # (@xterm/*) won't be present, and `vite build` fails to resolve it.
    # The frontend tracks no committed lockfile, so resolve from package.json.
    # pnpm v11's verify-deps hook breaks `pnpm <script>` invocations, so we
    # call the vite binary directly; plain `vite build` IS the production build.
    # pnpm v10+ exits non-zero on the ERR_PNPM_IGNORED_BUILDS advisory when a
    # dependency ships an un-approved build script (e.g. @swc/core) — even
    # though the install itself succeeded and this frontend builds fine
    # without those scripts (vite/swc/esbuild ship prebuilt binaries). Don't
    # let that advisory abort the ship: install best-effort, then assert the
    # install actually produced the vite binary so a REAL failure still dies,
    # and let `vite build` be the true gate.
    (cd "$fe" && CI=true pnpm install --no-frozen-lockfile) \
        || echo "    note: pnpm install exited non-zero (likely the ignored-build-scripts advisory); continuing — vite build is the gate"
    [[ -x "$fe/node_modules/.bin/vite" ]] \
        || die "pnpm install did not produce node_modules/.bin/vite (genuine install failure)"
    (cd "$fe" && CI=true ./node_modules/.bin/vite build) || die "vite build failed"

    mkdir -p "$dist"
    rsync -a --delete "$fe/dist/" "$dist/" || die "local frontend-dist sync failed"
    rsync -az --delete "$dist/" "$ssh_target:Adamaton-deploy/frontend-dist/" \
        || die "rsync to $host failed"
    ssh "$ssh_target" 'cd ~/Adamaton-deploy && docker compose restart frontend' \
        || die "frontend restart on $host failed"

    # Verify the bundle actually landed (the bind-mount inode trap serves
    # stale content silently otherwise).
    local lsum rsum
    lsum="$(sha256sum "$dist/index.html" | cut -d' ' -f1)"
    rsum="$(ssh "$ssh_target" 'sha256sum ~/Adamaton-deploy/frontend-dist/index.html' | cut -d' ' -f1)"
    [[ "$lsum" == "$rsum" ]] || die "index.html checksum mismatch after rsync"
    echo "    ok: frontend bundle live on $host (index.html ${lsum:0:12})"
}

cmd_ship() {
    [[ $# -ge 2 ]] || die "ship: usage: adam ship <host> <service> [<service2> ...]"
    load_ship_env
    local host="$1"; shift
    ensure_binfmt "$(host_platform "$host")"
    local svc spec sub_repo dockerfile context image target go_tags compose_svc service_name tag dirty img_ref status
    for svc in "$@"; do
        if [[ "$svc" == "frontend" ]]; then
            ship_frontend "$host"
            continue
        fi
        if ! spec="$(ship_service_spec "$svc")"; then
            die "no Dockerfile mapping for '$svc' (extend ship_service_spec in bin/adam)"
        fi
        # 4-field (legacy), 6-field (multi-stage target + build-arg), or
        # 7-field (+ compose_service override for deploy-agent restart
        # when the ship-spec key doesn't match the compose service name).
        # IFS-read tolerates trailing empty fields.
        target=""; go_tags=""; compose_svc=""
        IFS='|' read -r sub_repo dockerfile context image target go_tags compose_svc <<<"$spec"
        # service_name = what the deploy-agent's /restart endpoint
        # expects. Defaults to the ship-spec key (matches every legacy
        # entry); overridden to compose_svc when set (worker variants).
        service_name="${compose_svc:-$svc}"
        local sub_path="$ADAM_ROOT/$sub_repo"
        [[ -d "$sub_path/.git" || -f "$sub_path/.git" ]] || die "sub-repo '$sub_repo' is not a git checkout"

        # Refuse if dirty — workstation builds whatever the local tree has, so
        # an unclean repo would ship un-committed code.
        dirty="$(git_in "$sub_path" status --porcelain)"
        if [[ -n "$dirty" ]]; then
            die "$sub_repo has uncommitted changes; commit or stash first"
        fi

        tag="sha-$(git_in "$sub_path" rev-parse --short HEAD)"
        img_ref="${WORKSTATION_IP}:5000/${image}"
        echo "==> ship: $svc -> $img_ref:$tag"

        local buildx_args=(
            --platform "$(host_platform "$host")"
            --push
            -t "$img_ref:$tag"
            -t "$img_ref:main"
            -f "$ADAM_ROOT/$dockerfile"
        )
        if [[ -n "$target" ]]; then
            buildx_args+=(--target "$target")
        fi
        if [[ -n "$go_tags" ]]; then
            buildx_args+=(--build-arg "GO_TAGS=$go_tags")
        fi
        if ! docker buildx build "${buildx_args[@]}" "$ADAM_ROOT/$context"; then
            die "buildx failed for $svc"
        fi

        # Caddy on the Pi terminates TLS with a self-signed/local cert that
        # the workstation may not have in its trust store, so use.
        # The bearer token still authenticates the request inside the agent.
        local restart_url="$(host_deploy_url "$host")/restart?service=${service_name}&tag=${tag}"
        echo "    POST $restart_url"
        local resp
        if ! resp="$(curl -fsS \
                -X POST \
                -H "Authorization: Bearer $DEPLOY_AGENT_TOKEN" \
                "$restart_url" 2>&1)"; then
            die "deploy-agent rejected restart of $service_name on $host: $resp"
        fi

        # Poll /deploy/status until the new tag appears (or 60s elapse).
        local status_url="$(host_deploy_url "$host")/status?service=${service_name}"
        local waited=0 ok=0
        while (( waited < 60 )); do
            sleep 5
            waited=$((waited + 5))
            status="$(curl -fsS \
                -H "Authorization: Bearer $DEPLOY_AGENT_TOKEN" \
                "$status_url" 2>/dev/null || true)"
            if [[ "$status" == *"$tag"* ]]; then
                ok=1
                break
            fi
        done
        if [[ "$ok" -eq 1 ]]; then
            echo "    ok: $svc is on $tag (after ${waited}s)"
        else
            echo "adam: warning: $svc status did not reflect $tag within 60s on $host (deploy was accepted; check 'curl $status_url' manually)" >&2
        fi
    done
}

# cmd_rollback <host> <service> [<tag>]: redeploy a service to a PRIOR
# known-good image tag WITHOUT rebuilding — the tag must already exist in the
# workstation registry. POSTs the deploy-agent /restart, which (since the
# env-shadow + tag-verify fixes) pulls + force-recreates and confirms the
# running tag == requested before returning, then runs `fleet verify` as a
# second check. Omit <tag> to list the registry tags you can roll back to.
# The recovery half of the deploy-safety loop (card-529dbe2b).
cmd_rollback() {
    [[ $# -ge 2 ]] || die "rollback: usage: adam rollback <host> <service> [<tag>]  (omit <tag> to list available tags)"
    load_ship_env
    local host="$1" svc="$2" tag="${3:-}"

    # Resolve the registry image name + the compose service the agent restarts.
    local image service_name spec sub_repo dockerfile context img target go_tags compose_svc
    if spec="$(ship_service_spec "$svc")"; then
        IFS='|' read -r sub_repo dockerfile context img target go_tags compose_svc <<<"$spec"
        image="$img"; service_name="${compose_svc:-$svc}"
    else
        image="adamaton-$svc"; service_name="$svc"
    fi

    # No tag → list known-good tags from the registry and exit.
    if [[ -z "$tag" ]]; then
        echo "Recent registry tags for $image (roll back to one of these):"
        curl -fsS --max-time 5 "http://${WORKSTATION_IP}:5000/v2/${image}/tags/list" 2>/dev/null \
            | jq -r '.tags[]?' 2>/dev/null | grep '^sha-' | sort | tail -15 | sed 's/^/  /' \
            || echo "  (registry unreachable)"
        die "rollback: re-run with a tag, e.g. adam rollback $host $svc <tag>"
    fi

    echo "==> rollback: $service_name on $host -> $tag (no rebuild; tag must be in the registry)"
    local restart_url resp
    restart_url="$(host_deploy_url "$host")/restart?service=${service_name}&tag=${tag}"
    echo "    POST $restart_url"
    if ! resp="$(curl -fsS -X POST -H "Authorization: Bearer $DEPLOY_AGENT_TOKEN" "$restart_url" 2>&1)"; then
        die "deploy-agent rejected rollback of $service_name to $tag on $host: $resp"
    fi
    echo "    agent converged + verified $service_name on $tag"
    echo "==> post-rollback fleet verify ($host):"
    fleet_verify_one "$host" || true
}

cmd_ship_self() {
    [[ $# -ge 1 ]] || die "ship-self: usage: adam ship-self <host>"
    load_ship_env
    local host="$1"
    local sub_path="$ADAM_ROOT/platform"
    [[ -d "$sub_path/.git" || -f "$sub_path/.git" ]] || die "platform sub-repo is not a git checkout"

    local dirty
    dirty="$(git_in "$sub_path" status --porcelain)"
    if [[ -n "$dirty" ]]; then
        die "platform has uncommitted changes; commit or stash first"
    fi

    local tag="sha-$(git_in "$sub_path" rev-parse --short HEAD)"
    local img_ref="${WORKSTATION_IP}:5000/adamaton-deploy-agent"
    echo "==> ship-self: deploy-agent -> $img_ref:$tag on $host"

    ensure_binfmt "$(host_platform "$host")"
    if ! docker buildx build \
        --platform "$(host_platform "$host")" \
        --push \
        -t "$img_ref:$tag" \
        -t "$img_ref:main" \
        -f "$ADAM_ROOT/platform/deploy-agent/Dockerfile" \
        "$ADAM_ROOT"; then
        die "buildx failed for deploy-agent"
    fi

    # The agent can't restart itself (it would kill its own HTTP connection
    # mid-call), so we ssh in for this one. Bootstrap chicken-and-egg.
    local ssh_target https_target
    ssh_target=$(host_ssh_alias "$host")
    https_target=$(host_https_alias "$host")
    echo "    ssh $ssh_target: pin tag + compose up -d deploy-agent"
    if ! ssh "$ssh_target" "cd ~/Adamaton-deploy && sed -i 's/^ADAMATON_DEPLOY_AGENT_TAG=.*/ADAMATON_DEPLOY_AGENT_TAG=${tag}/' image-tags.env && docker compose --env-file .env --env-file image-tags.env pull deploy-agent && docker compose --env-file .env --env-file image-tags.env up -d deploy-agent"; then
        die "ssh-driven restart of deploy-agent on $ssh_target failed"
    fi

    # Give the agent a moment to come back, then poll /health.
    sleep 5
    local health_url="$(host_deploy_url "$host")/health"
    local waited=0 ok=0
    while (( waited < 30 )); do
        if curl -fsS --max-time 3 "$health_url" >/dev/null 2>&1; then
            ok=1
            break
        fi
        sleep 3
        waited=$((waited + 3))
    done
    if [[ "$ok" -eq 1 ]]; then
        echo "    ok: deploy-agent on $host is healthy on $tag (after ${waited}s)"
    else
        die "deploy-agent on $host did not return healthy within 30s; check 'ssh $host docker compose logs deploy-agent'"
    fi
}

# ---- bootstrap: chicken-and-egg first-deploy of deploy-agent ------------

# One-shot per-host bootstrap. Idempotent in every step except the docker
# daemon restart (which is a no-op if the insecure-registry is already
# allow-listed). Assumes:
#   - workstation registry is already running at ${WORKSTATION_IP}:5000
#   - ssh <host>.lan works without a password prompt
#   - the user on the host has passwordless sudo (for the daemon.json edit
#     + docker restart). If not, the operator gets a password prompt.
# cmd_sync_compose: scp deploy/<host>/docker-compose.yml (and
# .env.example, for reference) up to the host's ~/Adamaton-deploy/
# dir. `bin/adam ship` only pushes images — compose-file changes (new
# env vars, new service blocks) need this to actually reach the Pi.
#
# Intentionally minimal: no rsync, no drift detection, no merging with
# the host's docker-compose.override.yml. The operator is responsible
# for `cd ~/Adamaton-deploy && docker compose up -d --force-recreate
# --no-deps <svc>` afterwards to pick up the new env. (.env on the
# host is not touched — it's secret-bearing and operator-owned.)
cmd_sync_compose() {
    [[ $# -eq 1 ]] || die "sync-compose: usage: adam sync-compose <host>"
    local host="$1"
    local src="$ADAM_ROOT/deploy/$host/docker-compose.yml"
    [[ -f "$src" ]] || die "no compose file at $src"
    local ssh; ssh="$(host_ssh_alias "$host")"
    echo "==> sync-compose: $src -> $ssh:Adamaton-deploy/docker-compose.yml"
    scp "$src" "$ssh:Adamaton-deploy/docker-compose.yml" || die "scp failed"
    # .env.example is convenient as a reference for the operator; the
    # real .env stays untouched on the host.
    local env_src="$ADAM_ROOT/deploy/$host/.env.example"
    if [[ -f "$env_src" ]]; then
        echo "==> sync-compose: $env_src -> $ssh:Adamaton-deploy/.env.example"
        scp "$env_src" "$ssh:Adamaton-deploy/.env.example" || echo "    warning: env.example scp failed (non-fatal)" >&2
    fi
    # Caddyfile — Caddy is bind-mount-served; without this an edit to
    # the umbrella's Caddyfile never reaches the host. After a Caddyfile
    # change the operator should `docker compose restart frontend` to
    # avoid the pi-Caddy bind-mount inode trap (memory:
    # pi_caddy_bind_mount_inode).
    local caddy_src="$ADAM_ROOT/deploy/$host/Caddyfile"
    if [[ -f "$caddy_src" ]]; then
        echo "==> sync-compose: $caddy_src -> $ssh:Adamaton-deploy/Caddyfile"
        scp "$caddy_src" "$ssh:Adamaton-deploy/Caddyfile" || echo "    warning: Caddyfile scp failed (non-fatal)" >&2
    fi
    # Fleet-health topology — bind-mounted into evo-api at
    # /etc/adamaton/health-topology.yml. Single source-of-truth under
    # deploy/health/ (it's fleet-wide, not per-host); copied to the
    # per-host deploy dir on push.
    local topo_src="$ADAM_ROOT/deploy/health/topology.yml"
    if [[ -f "$topo_src" ]]; then
        echo "==> sync-compose: $topo_src -> $ssh:Adamaton-deploy/health-topology.yml"
        scp "$topo_src" "$ssh:Adamaton-deploy/health-topology.yml" || echo "    warning: topology scp failed (non-fatal)" >&2
    fi
    # MANIFEST.yaml — the deploy-agent's allow-list (which services it will
    # restart/scale/status). The agent reads it ONCE AT BOOT, so a change is
    # inert until the agent is recreated. Without this scp the on-host
    # allow-list silently drifts from the repo: a removed service stays
    # allow-listed (fleet verify shows it absent) and an added one is rejected
    # with "service not in allow-list".
    local manifest_src="$ADAM_ROOT/deploy/$host/MANIFEST.yaml"
    if [[ -f "$manifest_src" ]]; then
        echo "==> sync-compose: $manifest_src -> $ssh:Adamaton-deploy/MANIFEST.yaml"
        scp "$manifest_src" "$ssh:Adamaton-deploy/MANIFEST.yaml" || echo "    warning: MANIFEST scp failed (non-fatal)" >&2
    fi
    echo
    echo "Compose synced. To apply env changes for a service:"
    echo "  ssh $ssh 'cd Adamaton-deploy && docker compose up -d --force-recreate --no-deps <service>'"
    echo "If the Caddyfile changed:"
    echo "  ssh $ssh 'cd Adamaton-deploy && docker compose restart frontend'"
    echo "If MANIFEST.yaml changed (agent reads it at boot — restart to reload the allow-list):"
    echo "  ssh $ssh 'cd Adamaton-deploy && docker compose up -d --force-recreate --no-deps deploy-agent'"
    echo "Then confirm the fleet converged:"
    echo "  bin/adam fleet verify $host"
}

cmd_bootstrap() {
    [[ $# -eq 1 ]] || die "bootstrap: usage: adam bootstrap <host>"
    local host="$1"

    # Allow bootstrap with just WORKSTATION_IP — the token doesn't exist yet
    # on the first run. load_ship_env requires both, so we do a lighter check.
    local env_file="$HOME/.adamaton/ship.env"
    if [[ -f "$env_file" ]]; then
        # shellcheck disable=SC1090
        source "$env_file"
    fi
    : "${WORKSTATION_IP:=10.0.4.37}"

    # ssh target obeys ~/.ssh/config Host aliases (or HOST_SSH_<UPPER>);
    # https target is the Caddy cert SAN (HOST_HTTPS_<UPPER> override,
    # else <host>.local mDNS). These are usually different — e.g. ssh
    # alias 'pi5' -> deepresearch.local for the cert.
    local host_alias https_target
    host_alias=$(host_ssh_alias "$host")
    https_target=$(host_https_alias "$host")
    echo "==> bootstrap $host (ssh=$host_alias https=$https_target registry=${WORKSTATION_IP}:5000)"

    local deploy_src="$ADAM_ROOT/deploy/$host"
    [[ -d "$deploy_src" ]] || die "no such host: $deploy_src does not exist"
    [[ -f "$deploy_src/MANIFEST.yaml" ]] || die "$deploy_src/MANIFEST.yaml missing"

    # 1. Reachability check.
    echo "    [1/8] ssh reachability ($host_alias)"
    if ! ssh -o ConnectTimeout=5 -o BatchMode=yes "$host_alias" true 2>/dev/null; then
        die "cannot ssh $host_alias without a password — set up ssh-copy-id first"
    fi

    # 2. Registry reachability from workstation side. Cheap fail-fast.
    echo "    [2/8] workstation registry reachable"
    if ! curl -fsS --max-time 3 "http://${WORKSTATION_IP}:5000/v2/_catalog" >/dev/null; then
        die "workstation registry not reachable at ${WORKSTATION_IP}:5000 — start it with: docker run -d --restart=unless-stopped --name adamaton-registry -p 5000:5000 -v adamaton-registry-data:/var/lib/registry registry:2"
    fi

    # 3. Insecure-registry allow-list on the Pi. Idempotent — only writes
    # daemon.json if our entry is missing, then restarts docker.
    echo "    [3/8] /etc/docker/daemon.json allow-list (idempotent; may sudo)"
    local daemon_json
    daemon_json=$(cat <<EOF_DAEMON
{ "insecure-registries": ["${WORKSTATION_IP}:5000"] }
EOF_DAEMON
)
    ssh "$host_alias" "
        set -e
        if ! sudo grep -qF '${WORKSTATION_IP}:5000' /etc/docker/daemon.json 2>/dev/null; then
            sudo mkdir -p /etc/docker
            echo '$daemon_json' | sudo tee /etc/docker/daemon.json > /dev/null
            sudo systemctl restart docker
            sleep 2
        fi
    " || die "daemon.json install failed on $host_alias"

    # 4. Locate the on-host deploy dir. Convention: ~/Adamaton-deploy.
    local remote_dir
    remote_dir=$(ssh "$host_alias" 'echo $HOME/Adamaton-deploy' | tr -d '\r')
    [[ -n "$remote_dir" ]] || die "could not determine \$HOME on $host_alias"
    ssh "$host_alias" "mkdir -p '$remote_dir'"

    # Sync the latest deploy/<host>/ tree to the Pi so we have the new
    # compose, image-tags.env.example, etc. Excludes .env to preserve
    # the host's secrets across bootstrap runs.
    echo "    [3b/8] rsync deploy/$host/ -> $host_alias:$remote_dir/"
    if ! rsync -aP --partial \
            --exclude=.env \
            --exclude=image-tags.env \
            --exclude=up.sh \
            "$deploy_src/" "$host_alias:$remote_dir/"; then
        die "rsync deploy/$host/ to $host_alias failed"
    fi

    # 5. DEPLOY_AGENT_TOKEN: reuse if present on the Pi, else generate.
    echo "    [4/8] DEPLOY_AGENT_TOKEN on $host_alias"
    local remote_token
    remote_token=$(ssh "$host_alias" "
        cd $remote_dir
        existing=\$(grep -E '^DEPLOY_AGENT_TOKEN=' .env 2>/dev/null | tail -1 | cut -d= -f2-)
        if [[ -z \"\$existing\" ]]; then
            new_token=\$(openssl rand -hex 32)
            echo \"DEPLOY_AGENT_TOKEN=\$new_token\" >> .env
            echo \"\$new_token\"
        else
            echo \"\$existing\"
        fi
    ") || die "token install on $host_alias failed"
    [[ -n "$remote_token" ]] || die "empty token returned from $host_alias"

    # 6. image-tags.env: cp from .example if missing, then pin
    # ADAMATON_DEPLOY_AGENT_TAG=bootstrap for the first run.
    echo "    [5/8] image-tags.env initialized + pinned to 'bootstrap'"
    ssh "$host_alias" "
        set -e
        cd $remote_dir
        if [[ ! -f image-tags.env ]]; then
            cp image-tags.env.example image-tags.env
        fi
        if grep -qE '^ADAMATON_DEPLOY_AGENT_TAG=' image-tags.env; then
            sed -i 's/^ADAMATON_DEPLOY_AGENT_TAG=.*/ADAMATON_DEPLOY_AGENT_TAG=bootstrap/' image-tags.env
        else
            echo 'ADAMATON_DEPLOY_AGENT_TAG=bootstrap' >> image-tags.env
        fi
    " || die "image-tags.env setup on $host_alias failed"

    # 7. Build the bootstrap deploy-agent locally + scp+load to the Pi.
    # We bypass the registry on this one image (chicken-and-egg) by using
    # --load instead of --push, then docker save | ssh docker load.
    echo "    [6/8] building bootstrap deploy-agent (arm64, local load)"
    ensure_binfmt "$(host_platform "$host")"
    if ! docker buildx build \
            --platform "$(host_platform "$host")" \
            --load \
            -t "adamaton-deploy-agent:bootstrap" \
            -f "$ADAM_ROOT/platform/deploy-agent/Dockerfile" \
            "$ADAM_ROOT"; then
        die "buildx --load failed for deploy-agent bootstrap"
    fi

    echo "    [7/8] streaming bootstrap image to $host_alias"
    if ! docker save adamaton-deploy-agent:bootstrap | ssh "$host_alias" "
        set -e
        docker load
        # Compose references the image with the registry prefix, so retag
        # the just-loaded image under the prefix without pushing it.
        docker tag adamaton-deploy-agent:bootstrap '${WORKSTATION_IP}:5000/adamaton-deploy-agent:bootstrap'
    "; then
        die "docker save | ssh docker load failed for $host_alias"
    fi

    # 8. Bring the agent up + verify.
    # --env-file (passed twice) merges image-tags.env into the variables
    # docker compose uses to substitute ${ADAMATON_<SVC>_TAG} placeholders
    # in image: refs. Without this compose only sees vars from the
    # auto-loaded .env file, NOT from env_file: declarations (those only
    # populate container environments, not template substitutions).
    echo "    [8/8] docker compose up -d deploy-agent + health check"
    if ! ssh "$host_alias" "cd $remote_dir && docker compose --env-file .env --env-file image-tags.env up -d deploy-agent"; then
        die "docker compose up -d deploy-agent on $host_alias failed"
    fi
    sleep 5
    local health_url="$(host_deploy_url "$host")/health"
    local waited=0 ok=0
    while (( waited < 30 )); do
        if curl -fsS --max-time 3 "$health_url" >/dev/null 2>&1; then
            ok=1
            break
        fi
        sleep 3
        waited=$((waited + 3))
    done
    [[ "$ok" -eq 1 ]] || die "$health_url did not return healthy within 30s; check 'ssh $host_alias docker compose logs deploy-agent'"

    # Stash the host's token in ship.env so subsequent `ship` calls work.
    # Idempotent replace; never appends a duplicate. ship.env is per-host
    # tokens are awkward; for now we assume one token per workstation/fleet
    # — note this in the runbook.
    mkdir -p "$HOME/.adamaton"
    chmod 700 "$HOME/.adamaton"
    if [[ -f "$env_file" ]] && grep -qE '^DEPLOY_AGENT_TOKEN=' "$env_file"; then
        sed -i "s|^DEPLOY_AGENT_TOKEN=.*|DEPLOY_AGENT_TOKEN=${remote_token}|" "$env_file"
    else
        {
            grep -vE '^DEPLOY_AGENT_TOKEN=|^WORKSTATION_IP=' "$env_file" 2>/dev/null || true
            echo "WORKSTATION_IP=${WORKSTATION_IP}"
            echo "DEPLOY_AGENT_TOKEN=${remote_token}"
        } > "${env_file}.tmp" && mv "${env_file}.tmp" "$env_file"
    fi
    chmod 600 "$env_file"

    cat <<EOF_DONE

==> bootstrap complete on $host

  The agent is running on the 'bootstrap' tag (locally-loaded image; not
  in the registry). To switch to a registry-tagged build:

      adam ship-self $host

  Once on a registry tag, shipping other services is just:

      adam ship $host r2g
      adam ship $host plugin-host dispatch-worker

  ~/.adamaton/ship.env has been updated with the agent token.
EOF_DONE
}

# ---- dispatch ------------------------------------------------------------

if [[ $# -eq 0 ]]; then usage; exit 0; fi

case "$1" in
    claim)      shift; cmd_claim "$@" ;;
    release)    shift; cmd_release "$@" ;;
    status)     shift; cmd_status "$@" ;;
    sync-hooks) shift; cmd_sync_hooks "$@" ;;
    deploy)     shift; cmd_deploy "$@" ;;
    bump)       shift; cmd_bump "$@" ;;
    pin)        shift; cmd_pin "$@" ;;
    pull)       shift; cmd_pull "$@" ;;
    doctor)     shift; cmd_doctor "$@" ;;
    build)      shift; cmd_build "$@" ;;
    test)       shift; cmd_test "$@" ;;
    ci)         shift; cmd_ci "$@" ;;
    clean)      shift; cmd_clean "$@" ;;
    rescue)     shift; cmd_rescue "$@" ;;
    fleet)      shift; cmd_fleet "$@" ;;
    ship)         shift; cmd_ship "$@" ;;
    rollback)     shift; cmd_rollback "$@" ;;
    ship-self)    shift; cmd_ship_self "$@" ;;
    sync-compose) shift; cmd_sync_compose "$@" ;;
    bootstrap)    shift; cmd_bootstrap "$@" ;;
    help|-h|--help) usage ;;
    *) die "unknown subcommand '$1'; try 'adam help'" ;;
esac
