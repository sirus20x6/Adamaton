#!/usr/bin/env bash
# adam — Adamomaton agent-coordination CLI.
#
# Subcommands:
#   claim <scope>/<task>      create a worktree + branch + lockfile
#   release <scope>/<task>    push branch (optional), remove worktree, drop lockfile
#   status [--conflicts]      list active claims (and overlapping path warnings)
#   sync-hooks                install hooks/ templates into every submodule
#   deploy <host>             run deploy/<host>/up.sh
#   bump <sub-repo>           advance umbrella's submodule pin to its origin/main HEAD
#   pin <sub-repo>            show current umbrella pin for a sub-repo
#   pull                      git pull + git submodule update --recursive --remote
#   help [subcommand]
#
# Soft coordination: lockfiles in .locks/ describe active work but don't
# physically prevent overlap. The pre-push hook warns when pushing to a
# branch claimed by someone else; you can `--force` past it.

set -euo pipefail

# ---- globals -------------------------------------------------------------

# When invoked as $REPO/bin/adam, ADAM_ROOT is the umbrella root.
ADAM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LOCK_DIR="$ADAM_ROOT/.locks"
HOOKS_DIR="$ADAM_ROOT/hooks"
DEPLOY_DIR="$ADAM_ROOT/deploy"

CURRENT_AGENT="${ADAM_AGENT:-$(git config user.name 2>/dev/null || whoami)}"

# Submodule names recognised as <scope>. "cross" is a special scope that
# means "umbrella-level worktree containing all submodules".
SUBMODULES=(core frontend knowledge deepresearch platform delegator evolve)

# ---- helpers -------------------------------------------------------------

usage() {
    cat <<'EOF'
Usage: adam <subcommand> [args]

Worktree + branch coordination:
  claim <scope>/<task>      create a worktree + feature branch + lockfile
                            <scope> = one of core|frontend|knowledge|deepresearch|
                                      platform|delegator|evolve|cross
  release <scope>/<task>    remove the worktree, drop the lockfile
                            (--keep-branch to leave the branch unpushed)
  status [--conflicts]      list active claims
  rescue                    detect + recover from "edited main directly" mistakes
  clean [--force]           list (or remove with --force) stale lockfiles

Build + test + verify:
  doctor                    environment health check (git, gh, go, hooks, submodules)
  build <host>              cross-compile + tag images for <host>
                            <host> = pi5 | pi5-speaker | blackwell
  test [--scope=<sub>]      run go test ./... across all (or one) sub-repo

Hooks + submodules:
  sync-hooks                copy hooks/ templates into each submodule's .git/hooks/
  bump <sub-repo>           advance umbrella's submodule pin to origin/main HEAD
                            (the ONLY supported way to commit on main)
  pin <sub-repo>            print current umbrella SHA pin for a sub-repo
  pull                      umbrella pull + recursive submodule update

Fleet (multi-host rollouts):
  fleet status              show what image_tag each host's MANIFEST.yaml pins
  fleet pull <host|all>     ssh + docker compose pull + up -d, per host's MANIFEST
  fleet promote <sha-or-tag>  bulk-update every host's MANIFEST to a new tag

Single-host deploy:
  deploy <host>             run deploy/<host>/up.sh (rsync configs + compose up)

Push-deploy (workstation registry -> deploy-agent on host):
  bootstrap <host>          one-shot first-deploy: insecure-registry edit,
                            token gen, image-tags.env init, scp+load the
                            agent, compose up, health check, ship.env update.
                            Idempotent; safe to re-run. Needs ssh + sudo on host.
  ship <host> <service> ... build + push image(s) to the workstation registry,
                            then POST /deploy/restart on <host>.lan for each.
                            Reads token + registry IP from ~/.adamaton/ship.env.
                            Refuses to ship if the sub-repo is git-dirty.
  ship-self <host>          build + push deploy-agent and restart it on <host>
                            via ssh (the agent cannot self-restart safely).

  help [subcommand]
EOF
}

die() { echo "adam: error: $*" >&2; exit 2; }

# Normalize a scope/task string into ($scope $task). Aborts on bad shape.
parse_scope_task() {
    local arg="$1"
    if [[ "$arg" != */* ]]; then
        die "expected <scope>/<task>, got '$arg'"
    fi
    SCOPE="${arg%%/*}"
    TASK="${arg#*/}"
    if [[ -z "$SCOPE" || -z "$TASK" ]]; then
        die "scope and task must both be non-empty"
    fi
    # Sanity-check scope.
    local ok=0
    for s in "${SUBMODULES[@]}" cross; do
        if [[ "$s" == "$SCOPE" ]]; then ok=1; break; fi
    done
    if [[ "$ok" -ne 1 ]]; then
        die "unknown scope '$SCOPE'; valid: ${SUBMODULES[*]} cross"
    fi
}

lock_path() {
    echo "$LOCK_DIR/$1-$2.json"
}

write_lock() {
    local scope="$1" task="$2" branch="$3" worktree="$4" paths="$5"
    local now
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    cat > "$(lock_path "$scope" "$task")" <<EOF
{
  "agent":     "$CURRENT_AGENT",
  "scope":     "$scope",
  "task":      "$task",
  "branch":    "$branch",
  "worktree":  "$worktree",
  "paths":     [$paths],
  "started_at":"$now"
}
EOF
}

git_in() { git -C "$1" "${@:2}"; }

# ---- subcommands ---------------------------------------------------------

cmd_claim() {
    [[ $# -ge 1 ]] || die "claim: missing <scope>/<task>"
    parse_scope_task "$1"
    shift
    # Optional --paths "glob1,glob2,..."
    local paths_csv=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --paths) paths_csv="$2"; shift 2 ;;
            *) die "unknown flag '$1'" ;;
        esac
    done
    local paths_json=""
    if [[ -n "$paths_csv" ]]; then
        IFS=',' read -ra arr <<<"$paths_csv"
        for p in "${arr[@]}"; do
            paths_json+="\"$p\","
        done
        paths_json="${paths_json%,}"
    fi

    local lock_file
    lock_file="$(lock_path "$SCOPE" "$TASK")"
    if [[ -e "$lock_file" ]]; then
        die "claim already exists at $lock_file (use 'release' first, or --force)"
    fi

    local branch="$CURRENT_AGENT/$TASK"
    local worktree_path
    if [[ "$SCOPE" == "cross" ]]; then
        worktree_path="$ADAM_ROOT/worktrees/$CURRENT_AGENT-$TASK"
        git_in "$ADAM_ROOT" fetch
        git_in "$ADAM_ROOT" worktree add "$worktree_path" -b "$branch"
        git_in "$worktree_path" submodule update --init --recursive
    else
        local sub_repo="$ADAM_ROOT/$SCOPE"
        worktree_path="$sub_repo/$SCOPE-worktrees/$CURRENT_AGENT-$TASK"
        git_in "$sub_repo" fetch
        git_in "$sub_repo" worktree add "$worktree_path" -b "$branch" origin/main
    fi

    write_lock "$SCOPE" "$TASK" "$branch" "$worktree_path" "$paths_json"

    echo "claimed: $SCOPE/$TASK"
    echo "  agent:    $CURRENT_AGENT"
    echo "  branch:   $branch"
    echo "  worktree: $worktree_path"
    echo "  cd $worktree_path"
}

cmd_release() {
    [[ $# -ge 1 ]] || die "release: missing <scope>/<task>"
    parse_scope_task "$1"
    shift
    local keep_branch=0
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --keep-branch) keep_branch=1; shift ;;
            --force) force=1; shift ;;
            *) die "unknown flag '$1'" ;;
        esac
    done
    local lock_file
    lock_file="$(lock_path "$SCOPE" "$TASK")"
    [[ -e "$lock_file" ]] || die "no lockfile at $lock_file"

    local worktree branch
    worktree="$(grep -E '"worktree"' "$lock_file" | sed -E 's/.*"worktree" *: *"([^"]+)".*/\1/')"
    branch="$(grep -E '"branch"' "$lock_file" | sed -E 's/.*"branch" *: *"([^"]+)".*/\1/')"

    # Check for dirty changes.
    if [[ -d "$worktree" ]]; then
        if ! git_in "$worktree" diff --quiet || ! git_in "$worktree" diff --cached --quiet; then
            if [[ "$force" -ne 1 ]]; then
                die "worktree $worktree has uncommitted changes (use --force to discard)"
            fi
        fi
    fi

    # Remove the worktree.
    if [[ "$SCOPE" == "cross" ]]; then
        git_in "$ADAM_ROOT" worktree remove "$worktree" ${force:+--force}
    elif [[ -d "$worktree" ]]; then
        git_in "$ADAM_ROOT/$SCOPE" worktree remove "$worktree" ${force:+--force}
    fi

    # Delete branch unless asked to keep.
    if [[ "$keep_branch" -ne 1 ]]; then
        local repo
        if [[ "$SCOPE" == "cross" ]]; then repo="$ADAM_ROOT"; else repo="$ADAM_ROOT/$SCOPE"; fi
        # The branch may have already been pushed + merged; --delete will
        # only refuse if it's not merged. Use -D when --force.
        if [[ "$force" -eq 1 ]]; then
            git_in "$repo" branch -D "$branch" 2>/dev/null || true
        else
            git_in "$repo" branch --delete "$branch" 2>/dev/null || \
                echo "adam: branch $branch not deleted (not merged?); pass --force to drop anyway"
        fi
    fi

    rm "$lock_file"
    echo "released: $SCOPE/$TASK"
}

cmd_status() {
    local show_conflicts=0
    [[ "${1:-}" == "--conflicts" ]] && show_conflicts=1
    shopt -s nullglob
    local locks=("$LOCK_DIR"/*.json)
    shopt -u nullglob
    if [[ ${#locks[@]} -eq 0 ]]; then
        echo "no active claims"
        return 0
    fi
    printf "%-12s %-20s %-30s %s\n" "AGENT" "SCOPE/TASK" "BRANCH" "STARTED"
    for f in "${locks[@]}"; do
        local agent scope task branch started
        agent="$(grep -E '"agent"' "$f" | sed -E 's/.*"agent" *: *"([^"]+)".*/\1/')"
        scope="$(grep -E '"scope"' "$f" | sed -E 's/.*"scope" *: *"([^"]+)".*/\1/')"
        task="$(grep -E '"task"' "$f" | sed -E 's/.*"task" *: *"([^"]+)".*/\1/')"
        branch="$(grep -E '"branch"' "$f" | sed -E 's/.*"branch" *: *"([^"]+)".*/\1/')"
        started="$(grep -E '"started_at"' "$f" | sed -E 's/.*"started_at" *: *"([^"]+)".*/\1/')"
        printf "%-12s %-20s %-30s %s\n" "$agent" "$scope/$task" "$branch" "$started"
    done

    if [[ "$show_conflicts" -eq 1 ]]; then
        echo
        echo "(path-overlap detection not implemented yet — Phase 5 follow-up)"
    fi
}

cmd_sync_hooks() {
    [[ -d "$HOOKS_DIR" ]] || die "no $HOOKS_DIR — was the umbrella bootstrapped correctly?"
    local installed=0
    # Umbrella's own hooks.
    install_hooks_into "$ADAM_ROOT"
    installed=$((installed + 1))
    # Each submodule's hooks (path is .git file -> ../.git/modules/<sub>/).
    for sub in "${SUBMODULES[@]}"; do
        [[ -e "$ADAM_ROOT/$sub/.git" ]] || continue
        install_hooks_into "$ADAM_ROOT/$sub"
        installed=$((installed + 1))
    done
    echo "synced hooks into $installed checkouts"
}

install_hooks_into() {
    local dir="$1"
    # Resolve the actual git-dir (in submodules, .git is a file pointing
    # at ../.git/modules/<sub>/).
    local gitdir
    gitdir="$(git -C "$dir" rev-parse --git-dir)"
    if [[ "$gitdir" != /* ]]; then
        gitdir="$dir/$gitdir"
    fi
    mkdir -p "$gitdir/hooks"
    for h in pre-commit pre-push commit-msg; do
        [[ -f "$HOOKS_DIR/$h" ]] || continue
        cp "$HOOKS_DIR/$h" "$gitdir/hooks/$h"
        chmod +x "$gitdir/hooks/$h"
    done
    # Override any global core.hooksPath that would otherwise hide our
    # installed hooks. Users commonly set core.hooksPath in ~/.config/git
    # for their own dotfiles; without this local override our hooks would
    # never run (and the branch-enforcement guard would be silently
    # disabled). Submodule hooks live under the umbrella's
    # .git/modules/<sub>/hooks — point there explicitly.
    git -C "$dir" config core.hooksPath "$gitdir/hooks"
}

cmd_deploy() {
    [[ $# -ge 1 ]] || die "deploy: missing <host>"
    local host="$1"
    local up="$DEPLOY_DIR/$host/up.sh"
    [[ -x "$up" ]] || die "no executable $up"
    exec "$up"
}

cmd_bump() {
    [[ $# -ge 1 ]] || die "bump: missing <sub-repo>"
    local sub="$1"
    [[ -d "$ADAM_ROOT/$sub" ]] || die "no submodule '$sub' in umbrella"
    git_in "$ADAM_ROOT/$sub" fetch origin main
    git_in "$ADAM_ROOT/$sub" checkout origin/main
    local new_sha
    new_sha="$(git_in "$ADAM_ROOT/$sub" rev-parse HEAD)"
    git_in "$ADAM_ROOT" add "$sub"
    # ADAM_BUMP=1 tells pre-commit to allow this main-branch commit; without
    # it the hook rejects all direct main commits to force agents through
    # the bin/adam claim flow.
    ADAM_BUMP=1 git_in "$ADAM_ROOT" commit -m "bump $sub to $new_sha" || \
        echo "adam: no pin change for $sub (already at $new_sha)"
}

cmd_pin() {
    [[ $# -ge 1 ]] || die "pin: missing <sub-repo>"
    local sub="$1"
    git_in "$ADAM_ROOT" ls-tree HEAD "$sub" | awk '{print $3}'
}

cmd_pull() {
    git_in "$ADAM_ROOT" pull
    git_in "$ADAM_ROOT" submodule update --recursive --remote
}

# ---- doctor / build / test / clean / rescue -----------------------------

cmd_doctor() {
    local ok=1
    echo "==> Adamaton environment check"

    # 1. git config
    local name email
    name="$(git config user.name 2>/dev/null || true)"
    email="$(git config user.email 2>/dev/null || true)"
    if [[ -z "$name" || -z "$email" ]]; then
        echo "  [FAIL] git user.name/email not set"; ok=0
    else
        echo "  [ ok ] git config: $name <$email>"
    fi

    # 2. gh CLI + auth
    if ! command -v gh >/dev/null 2>&1; then
        echo "  [FAIL] gh CLI not installed"; ok=0
    elif ! gh auth status >/dev/null 2>&1; then
        echo "  [FAIL] gh not authenticated"; ok=0
    else
        echo "  [ ok ] gh authenticated"
    fi

    # 3. Go version
    if ! command -v go >/dev/null 2>&1; then
        echo "  [FAIL] go not installed"; ok=0
    else
        local gv
        gv="$(go version | awk '{print $3}')"
        echo "  [ ok ] $gv"
    fi

    # 4. Submodules initialized
    local uninit=0
    for sub in "${SUBMODULES[@]}"; do
        if [[ ! -d "$ADAM_ROOT/$sub/.git" && ! -f "$ADAM_ROOT/$sub/.git" ]]; then
            echo "  [FAIL] submodule '$sub' not initialized"; uninit=$((uninit+1)); ok=0
        fi
    done
    [[ "$uninit" -eq 0 ]] && echo "  [ ok ] all 7 submodules initialized"

    # 5. Hooks installed
    local hook_check
    hook_check="$(git -C "$ADAM_ROOT" rev-parse --git-dir)/hooks/pre-commit"
    if [[ -x "$hook_check" ]]; then
        echo "  [ ok ] umbrella hooks installed"
    else
        echo "  [WARN] umbrella hooks not installed — run: bin/adam sync-hooks"; ok=0
    fi

    # 6. Branch state (warn if on main with uncommitted changes in canonical checkout)
    local top branch dirty
    top="$(git -C "$ADAM_ROOT" rev-parse --show-toplevel)"
    branch="$(git -C "$ADAM_ROOT" symbolic-ref --short -q HEAD 2>/dev/null || echo HEAD)"
    dirty="$(git -C "$ADAM_ROOT" status --porcelain 2>/dev/null | head -1)"
    case "$top" in
        *-worktrees/*|*/worktrees/*) ;;
        *)
            if [[ "$branch" == "main" || "$branch" == "master" ]] && [[ -n "$dirty" ]]; then
                echo "  [WARN] you have uncommitted changes on '$branch' in the canonical checkout."
                echo "         pre-commit will reject these. Run: bin/adam rescue"
                ok=0
            fi
            ;;
    esac

    # 7. Umbrella pin freshness
    if git -C "$ADAM_ROOT" submodule status | grep -qE "^[+]"; then
        echo "  [WARN] one or more submodule pins are out of sync (run: bin/adam pull or bin/adam bump <sub>)"
    fi

    echo
    if [[ "$ok" -eq 1 ]]; then
        echo "✓ doctor: all green"
    else
        echo "✗ doctor: see warnings above"
        return 1
    fi
}

# Mapping of host -> components shipped on that host. Used by `bin/adam build`.
host_components() {
    case "$1" in
        pi5)         echo "skills-rae r2g reindex nano-research dashboard plugin-host dispatch evolve frontend reranker figure-renderer" ;;
        pi5-speaker) echo "nano-research figure-renderer" ;;
        blackwell)   echo "evo-worker-kernel" ;;
        workstation) echo "" ;;
        *) die "unknown host: $1 (valid: pi5 | pi5-speaker | blackwell | workstation)" ;;
    esac
}

cmd_build() {
    [[ $# -ge 1 ]] || die "build: missing <host>"
    local host="$1"
    local tag="${IMAGE_TAG:-$(git_in "$ADAM_ROOT" rev-parse --short HEAD)}"
    local comps; comps="$(host_components "$host")"
    if [[ -z "$comps" ]]; then
        echo "build: no components ship on $host (workstation runs no workers)"
        return 0
    fi
    echo "==> building images for $host at tag $tag"
    echo "   (delegates to Makefile pi-* targets; assumes you've run 'make pi-<comp>' OR run them here)"
    local c
    for c in $comps; do
        echo "  - $c -> adamaton-$c:$tag (pending Makefile target)"
    done
    echo
    echo "NOTE: bin/adam build is a stub. Run the Makefile targets directly for now:"
    echo "   make -C $ADAM_ROOT pi-$comps"
    echo "Then tag built images:"
    for c in $comps; do
        echo "   docker tag adamaton-$c:dev adamaton-$c:$tag"
    done
    echo "The future fleshing-out chains these automatically per host."
}

cmd_test() {
    local scope=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scope=*) scope="${1#--scope=}"; shift ;;
            *) die "unknown flag '$1'" ;;
        esac
    done
    local subs="${SUBMODULES[*]}"
    [[ -n "$scope" ]] && subs="$scope"
    local total_pass=0 total_fail=0
    for sub in $subs; do
        [[ -d "$ADAM_ROOT/$sub" ]] || continue
        # Find go modules under this sub-repo
        local gomods
        gomods="$(find "$ADAM_ROOT/$sub" -name 'go.mod' -not -path '*/node_modules/*' 2>/dev/null)"
        [[ -z "$gomods" ]] && continue
        for gomod in $gomods; do
            local dir; dir="$(dirname "$gomod")"
            printf "  %-40s " "${dir#$ADAM_ROOT/}"
            if (cd "$dir" && GOGENTS_SKIP_DOCKER_TESTS=1 go test -count=1 -timeout 60s ./... >/dev/null 2>&1); then
                echo "PASS"; total_pass=$((total_pass+1))
            else
                echo "FAIL"; total_fail=$((total_fail+1))
            fi
        done
    done
    echo
    echo "totals: $total_pass pass, $total_fail fail"
    [[ "$total_fail" -eq 0 ]]
}

cmd_clean() {
    local force=0
    [[ "${1:-}" == "--force" ]] && force=1
    echo "==> stale-worktree audit"
    local stale=()
    # Each lockfile's worktree; flag if absent on disk OR >7 days old.
    shopt -s nullglob
    for lock in "$LOCK_DIR"/*.json; do
        local wt started
        wt="$(grep -E '"worktree"' "$lock" | sed -E 's/.*"worktree" *: *"([^"]+)".*/\1/')"
        started="$(grep -E '"started_at"' "$lock" | sed -E 's/.*"started_at" *: *"([^"]+)".*/\1/')"
        if [[ ! -d "$wt" ]]; then
            echo "  STALE (no worktree on disk): $lock"
            stale+=("$lock")
            continue
        fi
        # 7-day age check
        if [[ -n "$started" ]]; then
            local age_days
            age_days=$(( ( $(date +%s) - $(date -d "$started" +%s 2>/dev/null || echo $(date +%s)) ) / 86400 ))
            if [[ "$age_days" -gt 7 ]]; then
                echo "  AGED (>${age_days}d, no recent activity): $lock"
                stale+=("$lock")
            fi
        fi
    done
    shopt -u nullglob
    if [[ ${#stale[@]} -eq 0 ]]; then
        echo "  no stale claims"
        return 0
    fi
    if [[ "$force" -eq 1 ]]; then
        echo "  --force: removing ${#stale[@]} stale lockfile(s)..."
        rm -f "${stale[@]}"
    else
        echo
        echo "Re-run with --force to delete the listed lockfiles."
    fi
}

cmd_rescue() {
    local top branch dirty
    top="$(git -C "$ADAM_ROOT" rev-parse --show-toplevel)"
    branch="$(git -C "$ADAM_ROOT" symbolic-ref --short -q HEAD 2>/dev/null || echo HEAD)"
    dirty="$(git -C "$ADAM_ROOT" status --porcelain 2>/dev/null)"

    case "$top" in
        *-worktrees/*|*/worktrees/*)
            echo "rescue: you're already in a worktree ($top). Nothing to do."
            return 0
            ;;
    esac

    if [[ "$branch" != "main" && "$branch" != "master" ]]; then
        echo "rescue: current branch is '$branch' (not main). Nothing to do."
        return 0
    fi

    if [[ -z "$dirty" ]]; then
        echo "rescue: working tree clean. Nothing to do."
        return 0
    fi

    echo "==> RESCUE: uncommitted changes on '$branch' in canonical checkout"
    echo
    echo "Changed files:"
    echo "$dirty" | sed 's/^/  /'
    echo
    echo "Recommended recovery:"
    echo "  1. Stash your changes:        git stash push -m 'rescue from main'"
    echo "  2. Claim a feature branch:    bin/adam claim <scope>/<task>"
    echo "  3. cd into the new worktree (path printed by claim)"
    echo "  4. Apply your stash:          git stash pop"
    echo "  5. Commit + push as usual"
    echo
    echo "Run with --auto to do steps 1-2 automatically (you still need to cd + stash pop)."
}

# ---- fleet: multi-host pull/promote/status -------------------------------

cmd_fleet() {
    local sub="${1:-status}"; shift || true
    case "$sub" in
        status)  fleet_status "$@" ;;
        pull)    fleet_pull "$@" ;;
        promote) fleet_promote "$@" ;;
        *) die "unknown fleet subcommand '$sub' (valid: status | pull | promote)" ;;
    esac
}

fleet_status() {
    echo "==> fleet status"
    for host in pi5 pi5-speaker blackwell; do
        local m="$DEPLOY_DIR/$host/MANIFEST.yaml"
        if [[ ! -f "$m" ]]; then
            echo "  $host: no MANIFEST.yaml"
            continue
        fi
        echo "  --- $host ---"
        # Print the manifest's image_tag + service list.
        grep -E "^(image_tag|services|  -)" "$m" | sed 's/^/    /'
    done
}

fleet_pull() {
    local host="${1:-}"
    [[ -z "$host" ]] && die "fleet pull: missing <host> (or 'all')"
    if [[ "$host" == "all" ]]; then
        for h in pi5 pi5-speaker blackwell; do fleet_pull_one "$h"; done
    else
        fleet_pull_one "$host"
    fi
}

fleet_pull_one() {
    local host="$1"
    local m="$DEPLOY_DIR/$host/MANIFEST.yaml"
    [[ -f "$m" ]] || die "no MANIFEST.yaml at $m"
    local tag
    tag="$(grep -E '^image_tag:' "$m" | sed -E 's/^image_tag: *"?([^"]+)"?/\1/')"
    echo "==> pulling on $host: image_tag=$tag"
    ssh "$host" "cd ~/Adamaton-deploy && IMAGE_TAG=$tag docker compose pull && IMAGE_TAG=$tag docker compose up -d && docker compose ps"
}

fleet_promote() {
    local tag="${1:-}"
    [[ -z "$tag" ]] && die "fleet promote: missing <sha-or-tag>"
    for host in pi5 pi5-speaker blackwell; do
        local m="$DEPLOY_DIR/$host/MANIFEST.yaml"
        [[ -f "$m" ]] || continue
        sed -i -E "s|^image_tag:.*|image_tag: \"$tag\"|" "$m"
        git_in "$ADAM_ROOT" add "$m"
    done
    ADAM_BUMP=1 git_in "$ADAM_ROOT" commit -m "fleet: promote to $tag" || \
        echo "adam: no manifest change (already at $tag)"
}

# ---- ship: build + push to workstation registry, restart on host --------

# Load DEPLOY_AGENT_TOKEN + WORKSTATION_IP from ~/.adamaton/ship.env. Both
# subcommands need them; missing file points the user at the runbook.
load_ship_env() {
    local env_file="$HOME/.adamaton/ship.env"
    if [[ ! -f "$env_file" ]]; then
        die "missing $env_file — see docs/PUSH_DEPLOY.md for one-time setup (token + WORKSTATION_IP)"
    fi
    # shellcheck disable=SC1090
    source "$env_file"
    [[ -n "${DEPLOY_AGENT_TOKEN:-}" ]] || die "$env_file must set DEPLOY_AGENT_TOKEN"
    [[ -n "${WORKSTATION_IP:-}" ]]     || die "$env_file must set WORKSTATION_IP"
}

# host_ssh_alias <host>: what name to pass to ssh. Honors HOST_SSH_<UPPER>
# from ship.env; falls back to the bare logical name so ~/.ssh/config
# Host stanzas resolve (e.g. `Host pi5\nHostName deepresearch.local`).
host_ssh_alias() {
    local h="$1" key
    key="HOST_SSH_$(echo "$h" | tr 'a-z-' 'A-Z_')"
    echo "${!key:-$h}"
}

# host_https_alias <host>: HTTPS hostname for Caddy. Honors
# HOST_HTTPS_<UPPER> (e.g. HOST_HTTPS_PI5=deepresearch.local), else
# defaults to <host>.local (mDNS convention). Use for curl; never ssh.
host_https_alias() {
    local h="$1" key
    key="HOST_HTTPS_$(echo "$h" | tr 'a-z-' 'A-Z_')"
    echo "${!key:-${h}.local}"
}

# host_deploy_url <host>: base URL for the deploy-agent (no trailing
# slash). Defaults to http://<mdns_alias>:9128 because not every host
# runs Caddy (pi5-speaker doesn't), and the bearer token is already
# the security boundary -- TLS adds no auth value over LAN-internal
# HTTP. Uses host_https_alias (mDNS .local by default, or the
# HOST_HTTPS_<H> override) for the hostname because ssh aliases from
# ~/.ssh/config aren't DNS-resolvable for curl. Override the whole URL
# with HOST_DEPLOY_URL_<UPPER> in ship.env when a host fronts the agent
# through HTTPS (e.g. https://deepresearch.local/deploy).
host_deploy_url() {
    local h="$1" key target
    key="HOST_DEPLOY_URL_$(echo "$h" | tr 'a-z-' 'A-Z_')"
    if [[ -n "${!key:-}" ]]; then
        echo "${!key}"
        return
    fi
    target=$(host_https_alias "$h")
    echo "http://${target}:9128"
}

# host_platform <host>: docker buildx --platform value. Honors
# HOST_PLATFORM_<UPPER> (e.g. HOST_PLATFORM_BLACKWELL=linux/amd64),
# defaults to linux/arm64 (the Pi default). Used by ship + ship-self
# + bootstrap so amd64 hosts don't end up with qemu-emulated arm64
# images.
host_platform() {
    local h="$1" key
    key="HOST_PLATFORM_$(echo "$h" | tr 'a-z-' 'A-Z_')"
    echo "${!key:-linux/arm64}"
}

# service -> "<sub_repo>|<dockerfile>|<context>|<image_name>"
# sub_repo is relative to $ADAM_ROOT and identifies which git checkout owns
# the source (used for SHA tag + dirty check). image_name is the registry
# repo name; several services share an image (nano-research-worker reuses
# the nano-research image; evo-api ships the dashboard binary under its own
# compose name; backend/worker-lo share platform-backend).
ship_service_spec() {
    case "$1" in
        # dashboard + evo-api use context=. because dashboard/go.mod has
        # replace directives that reach across to ../../core, ../../knowledge,
        # etc. Multi-stage build needs every sub-repo in the build context.
        dashboard)             echo "platform|platform/dashboard/Dockerfile|.|adamaton-dashboard" ;;
        plugin-host)           echo "platform|platform/plugin-host/Dockerfile|.|adamaton-plugin-host" ;;
        dispatch-worker)       echo "platform|platform/dispatch/Dockerfile|.|adamaton-dispatch-worker" ;;
        deploy-agent)          echo "platform|platform/deploy-agent/Dockerfile|.|adamaton-deploy-agent" ;;
        evo-api)               echo "platform|platform/dashboard/Dockerfile|.|adamaton-evo-api" ;;
        backend)               echo "platform|platform/backend/Dockerfile|platform/backend|adamaton-platform-backend" ;;
        worker-lo)             echo "platform|platform/backend/Dockerfile|platform/backend|adamaton-platform-backend" ;;
        r2g)                   echo "knowledge|knowledge/r2g/Dockerfile|knowledge/r2g|adamaton-r2g" ;;
        skills-rae)            echo "knowledge|knowledge/skills-rae/Dockerfile|.|adamaton-skills-rae" ;;
        skills-rae-worker)     echo "knowledge|knowledge/skills-rae/Dockerfile|.|adamaton-skills-rae-worker" ;;
        skills-worker)         echo "knowledge|knowledge/skills/Dockerfile|.|adamaton-skills-worker" ;;
        reindex-worker)        echo "knowledge|knowledge/reindex/Dockerfile|.|adamaton-reindex-worker" ;;
        nano-research)         echo "deepresearch|deepresearch/nano-research/Dockerfile|.|adamaton-nano-research" ;;
        nano-research-worker)  echo "deepresearch|deepresearch/nano-research/Dockerfile|.|adamaton-nano-research" ;;
        figure-renderer)       echo "deepresearch|deepresearch/nano-research/sidecars/figure-renderer/Dockerfile|deepresearch/nano-research/sidecars/figure-renderer|adamaton-nano-figure-renderer" ;;
        evo-worker)            echo "evolve|evolve/evolve/Dockerfile|.|adamaton-evo-worker" ;;
        *)                     return 1 ;;
    esac
}

cmd_ship() {
    [[ $# -ge 2 ]] || die "ship: usage: adam ship <host> <service> [<service2> ...]"
    load_ship_env
    local host="$1"; shift
    local svc spec sub_repo dockerfile context image tag dirty img_ref status
    for svc in "$@"; do
        if ! spec="$(ship_service_spec "$svc")"; then
            die "no Dockerfile mapping for '$svc' (extend ship_service_spec in bin/adam)"
        fi
        IFS='|' read -r sub_repo dockerfile context image <<<"$spec"
        local sub_path="$ADAM_ROOT/$sub_repo"
        [[ -d "$sub_path/.git" || -f "$sub_path/.git" ]] || die "sub-repo '$sub_repo' is not a git checkout"

        # Refuse if dirty — workstation builds whatever the local tree has, so
        # an unclean repo would ship un-committed code.
        dirty="$(git_in "$sub_path" status --porcelain)"
        if [[ -n "$dirty" ]]; then
            die "$sub_repo has uncommitted changes; commit or stash first"
        fi

        tag="sha-$(git_in "$sub_path" rev-parse --short HEAD)"
        img_ref="${WORKSTATION_IP}:5000/${image}"
        echo "==> ship: $svc -> $img_ref:$tag"

        if ! docker buildx build \
            --platform "$(host_platform "$host")" \
            --push \
            -t "$img_ref:$tag" \
            -t "$img_ref:main" \
            -f "$ADAM_ROOT/$dockerfile" \
            "$ADAM_ROOT/$context"; then
            die "buildx failed for $svc"
        fi

        # Caddy on the Pi terminates TLS with a self-signed/local cert that
        # the workstation may not have in its trust store, so use.
        # The bearer token still authenticates the request inside the agent.
        local restart_url="$(host_deploy_url "$host")/restart?service=${svc}&tag=${tag}"
        echo "    POST $restart_url"
        local resp
        if ! resp="$(curl -fsS \
                -X POST \
                -H "Authorization: Bearer $DEPLOY_AGENT_TOKEN" \
                "$restart_url" 2>&1)"; then
            die "deploy-agent rejected restart of $svc on $host: $resp"
        fi

        # Poll /deploy/status until the new tag appears (or 60s elapse).
        local status_url="$(host_deploy_url "$host")/status?service=${svc}"
        local waited=0 ok=0
        while (( waited < 60 )); do
            sleep 5
            waited=$((waited + 5))
            status="$(curl -fsS \
                -H "Authorization: Bearer $DEPLOY_AGENT_TOKEN" \
                "$status_url" 2>/dev/null || true)"
            if [[ "$status" == *"$tag"* ]]; then
                ok=1
                break
            fi
        done
        if [[ "$ok" -eq 1 ]]; then
            echo "    ok: $svc is on $tag (after ${waited}s)"
        else
            echo "adam: warning: $svc status did not reflect $tag within 60s on $host (deploy was accepted; check 'curl $status_url' manually)" >&2
        fi
    done
}

cmd_ship_self() {
    [[ $# -ge 1 ]] || die "ship-self: usage: adam ship-self <host>"
    load_ship_env
    local host="$1"
    local sub_path="$ADAM_ROOT/platform"
    [[ -d "$sub_path/.git" || -f "$sub_path/.git" ]] || die "platform sub-repo is not a git checkout"

    local dirty
    dirty="$(git_in "$sub_path" status --porcelain)"
    if [[ -n "$dirty" ]]; then
        die "platform has uncommitted changes; commit or stash first"
    fi

    local tag="sha-$(git_in "$sub_path" rev-parse --short HEAD)"
    local img_ref="${WORKSTATION_IP}:5000/adamaton-deploy-agent"
    echo "==> ship-self: deploy-agent -> $img_ref:$tag on $host"

    if ! docker buildx build \
        --platform "$(host_platform "$host")" \
        --push \
        -t "$img_ref:$tag" \
        -t "$img_ref:main" \
        -f "$ADAM_ROOT/platform/deploy-agent/Dockerfile" \
        "$ADAM_ROOT"; then
        die "buildx failed for deploy-agent"
    fi

    # The agent can't restart itself (it would kill its own HTTP connection
    # mid-call), so we ssh in for this one. Bootstrap chicken-and-egg.
    local ssh_target https_target
    ssh_target=$(host_ssh_alias "$host")
    https_target=$(host_https_alias "$host")
    echo "    ssh $ssh_target: pin tag + compose up -d deploy-agent"
    if ! ssh "$ssh_target" "cd ~/Adamaton-deploy && sed -i 's/^ADAMATON_DEPLOY_AGENT_TAG=.*/ADAMATON_DEPLOY_AGENT_TAG=${tag}/' image-tags.env && docker compose --env-file .env --env-file image-tags.env pull deploy-agent && docker compose --env-file .env --env-file image-tags.env up -d deploy-agent"; then
        die "ssh-driven restart of deploy-agent on $ssh_target failed"
    fi

    # Give the agent a moment to come back, then poll /health.
    sleep 5
    local health_url="$(host_deploy_url "$host")/health"
    local waited=0 ok=0
    while (( waited < 30 )); do
        if curl -fsS --max-time 3 "$health_url" >/dev/null 2>&1; then
            ok=1
            break
        fi
        sleep 3
        waited=$((waited + 3))
    done
    if [[ "$ok" -eq 1 ]]; then
        echo "    ok: deploy-agent on $host is healthy on $tag (after ${waited}s)"
    else
        die "deploy-agent on $host did not return healthy within 30s; check 'ssh $host docker compose logs deploy-agent'"
    fi
}

# ---- bootstrap: chicken-and-egg first-deploy of deploy-agent ------------

# One-shot per-host bootstrap. Idempotent in every step except the docker
# daemon restart (which is a no-op if the insecure-registry is already
# allow-listed). Assumes:
#   - workstation registry is already running at ${WORKSTATION_IP}:5000
#   - ssh <host>.lan works without a password prompt
#   - the user on the host has passwordless sudo (for the daemon.json edit
#     + docker restart). If not, the operator gets a password prompt.
cmd_bootstrap() {
    [[ $# -eq 1 ]] || die "bootstrap: usage: adam bootstrap <host>"
    local host="$1"

    # Allow bootstrap with just WORKSTATION_IP — the token doesn't exist yet
    # on the first run. load_ship_env requires both, so we do a lighter check.
    local env_file="$HOME/.adamaton/ship.env"
    if [[ -f "$env_file" ]]; then
        # shellcheck disable=SC1090
        source "$env_file"
    fi
    : "${WORKSTATION_IP:=10.0.4.37}"

    # ssh target obeys ~/.ssh/config Host aliases (or HOST_SSH_<UPPER>);
    # https target is the Caddy cert SAN (HOST_HTTPS_<UPPER> override,
    # else <host>.local mDNS). These are usually different — e.g. ssh
    # alias 'pi5' -> deepresearch.local for the cert.
    local host_alias https_target
    host_alias=$(host_ssh_alias "$host")
    https_target=$(host_https_alias "$host")
    echo "==> bootstrap $host (ssh=$host_alias https=$https_target registry=${WORKSTATION_IP}:5000)"

    local deploy_src="$ADAM_ROOT/deploy/$host"
    [[ -d "$deploy_src" ]] || die "no such host: $deploy_src does not exist"
    [[ -f "$deploy_src/MANIFEST.yaml" ]] || die "$deploy_src/MANIFEST.yaml missing"

    # 1. Reachability check.
    echo "    [1/8] ssh reachability ($host_alias)"
    if ! ssh -o ConnectTimeout=5 -o BatchMode=yes "$host_alias" true 2>/dev/null; then
        die "cannot ssh $host_alias without a password — set up ssh-copy-id first"
    fi

    # 2. Registry reachability from workstation side. Cheap fail-fast.
    echo "    [2/8] workstation registry reachable"
    if ! curl -fsS --max-time 3 "http://${WORKSTATION_IP}:5000/v2/_catalog" >/dev/null; then
        die "workstation registry not reachable at ${WORKSTATION_IP}:5000 — start it with: docker run -d --restart=unless-stopped --name adamaton-registry -p 5000:5000 -v adamaton-registry-data:/var/lib/registry registry:2"
    fi

    # 3. Insecure-registry allow-list on the Pi. Idempotent — only writes
    # daemon.json if our entry is missing, then restarts docker.
    echo "    [3/8] /etc/docker/daemon.json allow-list (idempotent; may sudo)"
    local daemon_json
    daemon_json=$(cat <<EOF_DAEMON
{ "insecure-registries": ["${WORKSTATION_IP}:5000"] }
EOF_DAEMON
)
    ssh "$host_alias" "
        set -e
        if ! sudo grep -qF '${WORKSTATION_IP}:5000' /etc/docker/daemon.json 2>/dev/null; then
            sudo mkdir -p /etc/docker
            echo '$daemon_json' | sudo tee /etc/docker/daemon.json > /dev/null
            sudo systemctl restart docker
            sleep 2
        fi
    " || die "daemon.json install failed on $host_alias"

    # 4. Locate the on-host deploy dir. Convention: ~/Adamaton-deploy.
    local remote_dir
    remote_dir=$(ssh "$host_alias" 'echo $HOME/Adamaton-deploy' | tr -d '\r')
    [[ -n "$remote_dir" ]] || die "could not determine \$HOME on $host_alias"
    ssh "$host_alias" "mkdir -p '$remote_dir'"

    # Sync the latest deploy/<host>/ tree to the Pi so we have the new
    # compose, image-tags.env.example, etc. Excludes .env to preserve
    # the host's secrets across bootstrap runs.
    echo "    [3b/8] rsync deploy/$host/ -> $host_alias:$remote_dir/"
    if ! rsync -aP --partial \
            --exclude=.env \
            --exclude=image-tags.env \
            --exclude=up.sh \
            "$deploy_src/" "$host_alias:$remote_dir/"; then
        die "rsync deploy/$host/ to $host_alias failed"
    fi

    # 5. DEPLOY_AGENT_TOKEN: reuse if present on the Pi, else generate.
    echo "    [4/8] DEPLOY_AGENT_TOKEN on $host_alias"
    local remote_token
    remote_token=$(ssh "$host_alias" "
        cd $remote_dir
        existing=\$(grep -E '^DEPLOY_AGENT_TOKEN=' .env 2>/dev/null | tail -1 | cut -d= -f2-)
        if [[ -z \"\$existing\" ]]; then
            new_token=\$(openssl rand -hex 32)
            echo \"DEPLOY_AGENT_TOKEN=\$new_token\" >> .env
            echo \"\$new_token\"
        else
            echo \"\$existing\"
        fi
    ") || die "token install on $host_alias failed"
    [[ -n "$remote_token" ]] || die "empty token returned from $host_alias"

    # 6. image-tags.env: cp from .example if missing, then pin
    # ADAMATON_DEPLOY_AGENT_TAG=bootstrap for the first run.
    echo "    [5/8] image-tags.env initialized + pinned to 'bootstrap'"
    ssh "$host_alias" "
        set -e
        cd $remote_dir
        if [[ ! -f image-tags.env ]]; then
            cp image-tags.env.example image-tags.env
        fi
        if grep -qE '^ADAMATON_DEPLOY_AGENT_TAG=' image-tags.env; then
            sed -i 's/^ADAMATON_DEPLOY_AGENT_TAG=.*/ADAMATON_DEPLOY_AGENT_TAG=bootstrap/' image-tags.env
        else
            echo 'ADAMATON_DEPLOY_AGENT_TAG=bootstrap' >> image-tags.env
        fi
    " || die "image-tags.env setup on $host_alias failed"

    # 7. Build the bootstrap deploy-agent locally + scp+load to the Pi.
    # We bypass the registry on this one image (chicken-and-egg) by using
    # --load instead of --push, then docker save | ssh docker load.
    echo "    [6/8] building bootstrap deploy-agent (arm64, local load)"
    if ! docker buildx build \
            --platform "$(host_platform "$host")" \
            --load \
            -t "adamaton-deploy-agent:bootstrap" \
            -f "$ADAM_ROOT/platform/deploy-agent/Dockerfile" \
            "$ADAM_ROOT"; then
        die "buildx --load failed for deploy-agent bootstrap"
    fi

    echo "    [7/8] streaming bootstrap image to $host_alias"
    if ! docker save adamaton-deploy-agent:bootstrap | ssh "$host_alias" "
        set -e
        docker load
        # Compose references the image with the registry prefix, so retag
        # the just-loaded image under the prefix without pushing it.
        docker tag adamaton-deploy-agent:bootstrap '${WORKSTATION_IP}:5000/adamaton-deploy-agent:bootstrap'
    "; then
        die "docker save | ssh docker load failed for $host_alias"
    fi

    # 8. Bring the agent up + verify.
    # --env-file (passed twice) merges image-tags.env into the variables
    # docker compose uses to substitute ${ADAMATON_<SVC>_TAG} placeholders
    # in image: refs. Without this compose only sees vars from the
    # auto-loaded .env file, NOT from env_file: declarations (those only
    # populate container environments, not template substitutions).
    echo "    [8/8] docker compose up -d deploy-agent + health check"
    if ! ssh "$host_alias" "cd $remote_dir && docker compose --env-file .env --env-file image-tags.env up -d deploy-agent"; then
        die "docker compose up -d deploy-agent on $host_alias failed"
    fi
    sleep 5
    local health_url="$(host_deploy_url "$host")/health"
    local waited=0 ok=0
    while (( waited < 30 )); do
        if curl -fsS --max-time 3 "$health_url" >/dev/null 2>&1; then
            ok=1
            break
        fi
        sleep 3
        waited=$((waited + 3))
    done
    [[ "$ok" -eq 1 ]] || die "$health_url did not return healthy within 30s; check 'ssh $host_alias docker compose logs deploy-agent'"

    # Stash the host's token in ship.env so subsequent `ship` calls work.
    # Idempotent replace; never appends a duplicate. ship.env is per-host
    # tokens are awkward; for now we assume one token per workstation/fleet
    # — note this in the runbook.
    mkdir -p "$HOME/.adamaton"
    chmod 700 "$HOME/.adamaton"
    if [[ -f "$env_file" ]] && grep -qE '^DEPLOY_AGENT_TOKEN=' "$env_file"; then
        sed -i "s|^DEPLOY_AGENT_TOKEN=.*|DEPLOY_AGENT_TOKEN=${remote_token}|" "$env_file"
    else
        {
            grep -vE '^DEPLOY_AGENT_TOKEN=|^WORKSTATION_IP=' "$env_file" 2>/dev/null || true
            echo "WORKSTATION_IP=${WORKSTATION_IP}"
            echo "DEPLOY_AGENT_TOKEN=${remote_token}"
        } > "${env_file}.tmp" && mv "${env_file}.tmp" "$env_file"
    fi
    chmod 600 "$env_file"

    cat <<EOF_DONE

==> bootstrap complete on $host

  The agent is running on the 'bootstrap' tag (locally-loaded image; not
  in the registry). To switch to a registry-tagged build:

      adam ship-self $host

  Once on a registry tag, shipping other services is just:

      adam ship $host r2g
      adam ship $host plugin-host dispatch-worker

  ~/.adamaton/ship.env has been updated with the agent token.
EOF_DONE
}

# ---- dispatch ------------------------------------------------------------

if [[ $# -eq 0 ]]; then usage; exit 0; fi

case "$1" in
    claim)      shift; cmd_claim "$@" ;;
    release)    shift; cmd_release "$@" ;;
    status)     shift; cmd_status "$@" ;;
    sync-hooks) shift; cmd_sync_hooks "$@" ;;
    deploy)     shift; cmd_deploy "$@" ;;
    bump)       shift; cmd_bump "$@" ;;
    pin)        shift; cmd_pin "$@" ;;
    pull)       shift; cmd_pull "$@" ;;
    doctor)     shift; cmd_doctor "$@" ;;
    build)      shift; cmd_build "$@" ;;
    test)       shift; cmd_test "$@" ;;
    clean)      shift; cmd_clean "$@" ;;
    rescue)     shift; cmd_rescue "$@" ;;
    fleet)      shift; cmd_fleet "$@" ;;
    ship)       shift; cmd_ship "$@" ;;
    ship-self)  shift; cmd_ship_self "$@" ;;
    bootstrap)  shift; cmd_bootstrap "$@" ;;
    help|-h|--help) usage ;;
    *) die "unknown subcommand '$1'; try 'adam help'" ;;
esac
