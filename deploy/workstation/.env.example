# deploy/workstation/.env.example — copy to .env locally (NOT committed).

# ---- Postgres ------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
# Host port 5432 is reserved for a possible system-installed postgres; 5433
# is the convention used by /thearray/git/evo/docker-compose.postgres.yml.
POSTGRES_HOST_PORT=5433

# ---- Workstation registry (push-deploy) ---------------------------------
# IP of the workstation hosting the private container registry at :5000.
# Image refs in docker-compose.yml resolve to ${WORKSTATION_IP}:5000/...
WORKSTATION_IP=10.0.4.37

# ---- deploy-agent -------------------------------------------------------
# Bearer token; same as the other hosts' .env (one token per fleet).
DEPLOY_AGENT_TOKEN=

# ---- Worker template substitution ---------------------------------------
# Consumed by docker-compose.workers.yml blocks the deploy-agent renders
# from deploy/worker-types/*.yml. Workstation hits pi5 over LAN for the
# shared services (postgres, temporal, backend, skills-rae, r2g).
WORKER_HOSTNAME=workstation
WORKER_POSTGRES_HOST=10.0.4.30
WORKER_TEMPORAL_HOST=10.0.4.30
WORKER_BACKEND_HOST=10.0.4.30
WORKER_SKILLS_RAE_HOST=10.0.4.30
WORKER_R2G_HOST=10.0.4.30
WORKER_FIGURE_RENDERER_HOST=10.0.4.30
