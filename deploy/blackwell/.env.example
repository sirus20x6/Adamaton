# deploy/blackwell/.env.example — copy to .env on the GPU node (NOT committed).

# ---- Image tag stamped by up.sh from `git rev-parse --short HEAD` -------
IMAGE_TAG=dev

# ---- Pi #1 LAN address (Temporal + Postgres live there) -----------------
PI1_HOST=10.0.4.30
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ---- vLLM ---------------------------------------------------------------
# Image and model are bumped here, not in compose, so a deploy doesn't
# require a code change. Keep VLLM_SERVED_MODEL aligned with what
# nano-research-worker (QWEN_MODEL_ID) and evo-worker (EVO_LLM_MODEL) ask for.
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct-FP8
VLLM_SERVED_MODEL=qwen3.6-27b-nvfp8
VLLM_MAX_LORAS=4
VLLM_MAX_LORA_RANK=64
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEM_UTIL=0.90
NVIDIA_VISIBLE_DEVICES=all

# Disk paths for HF cache + LoRA adapters + distill output. The vLLM image
# downloads ~60GB of weights on first boot; persist them on /srv.
HF_CACHE_DIR=/srv/checkpoints/hf
LORA_DIR=/srv/checkpoints/lora
DISTILL_OUTPUT_DIR=/srv/checkpoints/distill

# ---- evo-worker (KernelBench queue) -------------------------------------
EVO_KERNEL_TASK_QUEUE=evo-kernel

# ---- Distill trainer (manual, profile=train) ----------------------------
WANDB_API_KEY=
