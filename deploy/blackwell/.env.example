# deploy/blackwell/.env.example — copy to .env on the GPU node (NOT committed).

# ---- Image tag stamped by up.sh from `git rev-parse --short HEAD` -------
IMAGE_TAG=dev

# ---- Pi #1 LAN address (Temporal + Postgres live there) -----------------
PI1_HOST=10.0.4.30
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ---- vLLM ---------------------------------------------------------------
# Image and model are bumped here, not in compose, so a deploy doesn't
# require a code change. Keep VLLM_SERVED_MODEL aligned with what
# nano-research-worker (QWEN_MODEL_ID) and evo-worker (EVO_LLM_MODEL) ask for.
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct-FP8
VLLM_SERVED_MODEL=qwen3.6-27b-nvfp8
VLLM_MAX_LORAS=4
VLLM_MAX_LORA_RANK=64
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEM_UTIL=0.90
NVIDIA_VISIBLE_DEVICES=all

# Disk paths for HF cache + LoRA adapters + distill output. The vLLM image
# downloads ~60GB of weights on first boot; persist them on /srv.
HF_CACHE_DIR=/srv/checkpoints/hf
LORA_DIR=/srv/checkpoints/lora
DISTILL_OUTPUT_DIR=/srv/checkpoints/distill

# ---- evo-worker (KernelBench queue) -------------------------------------
EVO_KERNEL_TASK_QUEUE=evo-kernel

# ---- Distill trainer (manual, profile=train) ----------------------------
WANDB_API_KEY=

# ---- Workstation registry (push-deploy) ---------------------------------
# IP of the workstation hosting the private container registry at :5000.
# Image refs in docker-compose.yml resolve to ${WORKSTATION_IP}:5000/...
WORKSTATION_IP=10.0.4.37

# ---- Sidecars on workstation -------------------------------------------
# BGE_EMBED_URL is the post-Python-elim embed endpoint (llama-server).
# BGE_SIDECAR_URL is the legacy Python sidecar (still hosts rerank).
BGE_EMBED_URL=http://10.0.4.37:8092
BGE_SIDECAR_URL=http://10.0.4.37:8089

# ---- deploy-agent -------------------------------------------------------
# Bearer token the workstation presents on POST /deploy/restart. Generate
# with `openssl rand -hex 32` and stash on the workstation in
# ~/.adamaton/ship.env so `bin/adam ship` can pick it up.
DEPLOY_AGENT_TOKEN=

# ---- Worker template substitution ---------------------------------------
# Consumed by docker-compose.workers.yml blocks the deploy-agent renders
# from deploy/worker-types/*.yml. Blackwell hits pi5 over LAN for the
# shared services.
WORKER_HOSTNAME=blackwell
WORKER_POSTGRES_HOST=10.0.4.30
WORKER_TEMPORAL_HOST=10.0.4.30
WORKER_BACKEND_HOST=10.0.4.30
WORKER_SKILLS_RAE_HOST=10.0.4.30
WORKER_R2G_HOST=10.0.4.30
WORKER_FIGURE_RENDERER_HOST=10.0.4.30
