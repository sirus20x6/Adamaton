# deploy/blackwell/image-tags.env.example — per-service image tags for blackwell.
#
# Consumed via `env_file: [.env, image-tags.env]` on every adamaton-* service
# in deploy/blackwell/docker-compose.yml. Copy to image-tags.env on first
# deploy (cp image-tags.env.example image-tags.env); the deploy-agent
# rewrites the affected line in place on every POST /deploy/restart call.
#
# vLLM is an upstream image (vllm/vllm-openai), pinned via VLLM_IMAGE in
# .env -- not bumped through the deploy-agent.

ADAMATON_DEPLOY_AGENT_TAG=main
ADAMATON_DISTILL_TRAINER_TAG=main

# Unified worker (gpu variant on blackwell). Pins
# adamaton-worker-gpu:<tag>; the variant is in the image name.
ADAMATON_WORKER_TAG=main

# DEPRECATED — kept for one release cycle so `bin/adam deploy --rollback`
# can re-spawn the standalone evo-worker-kernel service block. Remove
# after the rollback window closes.
ADAMATON_EVO_WORKER_TAG=main
