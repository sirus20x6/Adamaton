# deploy/pi5-speaker/image-tags.env.example — per-service image tags for pi5-speaker.
#
# Consumed via `env_file: [.env, image-tags.env]` on every adamaton-* service
# in deploy/pi5-speaker/docker-compose.yml. Copy to image-tags.env on first
# deploy (cp image-tags.env.example image-tags.env); the deploy-agent
# rewrites the affected line in place on every POST /deploy/restart call.
#
# Note: nano-research-worker shares the adamaton-nano-research image with
# the pi5 nano-research service, so it tracks ADAMATON_NANO_RESEARCH_TAG.

ADAMATON_DEPLOY_AGENT_TAG=main
ADAMATON_FIGURE_RENDERER_TAG=main
ADAMATON_NANO_RESEARCH_TAG=main
