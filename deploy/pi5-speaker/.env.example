# deploy/pi5-speaker/.env.example — copy to .env on the replica Pi (NOT committed).

# ---- Image tag stamped by up.sh from `git rev-parse --short HEAD` -------
IMAGE_TAG=dev

# ---- Pi #1 LAN address --------------------------------------------------
# eth0 IP of the main Pi. Use the literal address, not the hostname, so
# the worker stays up even if mDNS hiccups. Seed via:
#   ssh pi5 'ip -4 addr show eth0 | awk "/inet /{sub(/\\/.*/,\"\"); print \$2; exit}"'
PI1_HOST=10.0.4.30

# ---- Postgres creds (must match deploy/pi5/.env) ------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ---- LLM endpoints (workstation vLLM) -----------------------------------
QWEN_BASE_URL=http://10.0.4.37:9080/v1
QWEN_MODEL=qwen3.6-27b-nvfp8
QWEN_MODEL_ID=qwen3.6-27b-nvfp8

# ---- nano-research log verbosity ----------------------------------------
NANO_RESEARCH_LOG_LEVEL=info

# ---- Workstation registry (push-deploy) ---------------------------------
# IP of the workstation hosting the private container registry at :5000.
# Image refs in docker-compose.yml resolve to ${WORKSTATION_IP}:5000/...
WORKSTATION_IP=10.0.4.37

# ---- Sidecars on workstation -------------------------------------------
# BGE_EMBED_URL is the post-Python-elim embed endpoint (llama-server).
# BGE_SIDECAR_URL is the legacy Python sidecar (still hosts rerank).
BGE_EMBED_URL=http://10.0.4.37:8092
BGE_SIDECAR_URL=http://10.0.4.37:8089

# ---- deploy-agent -------------------------------------------------------
# Bearer token the workstation presents on POST /deploy/restart. Generate
# with `openssl rand -hex 32` and stash on the workstation in
# ~/.adamaton/ship.env so `bin/adam ship` can pick it up.
DEPLOY_AGENT_TOKEN=

# ---- Worker template substitution ---------------------------------------
# Consumed by docker-compose.workers.yml blocks the deploy-agent renders
# from deploy/worker-types/*.yml. Replica node hits pi5 over LAN for the
# shared services; figure-renderer is local.
WORKER_HOSTNAME=pi5-speaker
WORKER_POSTGRES_HOST=10.0.4.30
WORKER_TEMPORAL_HOST=10.0.4.30
WORKER_BACKEND_HOST=10.0.4.30
WORKER_SKILLS_RAE_HOST=10.0.4.30
WORKER_R2G_HOST=10.0.4.30
WORKER_FIGURE_RENDERER_HOST=figure-renderer
