# deploy/pi5-speaker/.env.example — copy to .env on the replica Pi (NOT committed).

# ---- Image tag stamped by up.sh from `git rev-parse --short HEAD` -------
IMAGE_TAG=dev

# ---- Pi #1 LAN address --------------------------------------------------
# eth0 IP of the main Pi. Use the literal address, not the hostname, so
# the worker stays up even if mDNS hiccups. Seed via:
#   ssh pi5 'ip -4 addr show eth0 | awk "/inet /{sub(/\\/.*/,\"\"); print \$2; exit}"'
PI1_HOST=10.0.4.30

# ---- Postgres creds (must match deploy/pi5/.env) ------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ---- LLM endpoints (workstation vLLM) -----------------------------------
QWEN_BASE_URL=http://10.0.4.37:9080/v1
QWEN_MODEL=qwen3.6-27b-nvfp8
QWEN_MODEL_ID=qwen3.6-27b-nvfp8

# ---- nano-research log verbosity ----------------------------------------
NANO_RESEARCH_LOG_LEVEL=info
