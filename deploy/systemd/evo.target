# /thearray/git/evo/systemd/evo.target
[Unit]
Description=GoGents AI Code Review System
Documentation=https://github.com/thearray/git/evo
Requires=temporal-server.service
After=temporal-server.service
Wants=evo-api.service evo-worker@1.service evo-worker@2.service temporal-server.service

[Install]
WantedBy=multi-user.target
