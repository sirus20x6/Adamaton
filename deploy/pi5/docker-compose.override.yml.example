# Pi-local docker-compose override — copy to docker-compose.override.yml on
# the Pi (NOT committed; this is the template). docker-compose loads
# .override.yml automatically; it layers on top of docker-compose.yml.
#
# Why this exists: the Python platform backend (services 'backend' and
# 'worker-lo') runs from a host-mounted source tree at first install,
# not a baked-in image. The canonical compose declares the image but
# omits the bind mounts so the file works in any environment. This
# override re-attaches the bind mounts the way the legacy ~/deepresearch
# stack did, so 'pip install -e /r2r[core]' and 'alembic upgrade head' at
# container start can find the source.
#
# Prerequisites on the Pi (one-time setup):
#   ln -s /home/sirus/deepresearch/platform /home/sirus/Adamaton-deploy/platform
#   ln -s /home/sirus/deepresearch/R2R       /home/sirus/Adamaton-deploy/R2R
# (The symlinks point at the legacy source dirs; the bind mounts below
# resolve through them.)
#
# When the platform/backend is rebuilt as a single self-contained image
# (Go-port or fat-Python), delete this override.

services:
  backend:
    volumes:
      - ./platform/backend:/app:rw
      - ./R2R/py:/r2r:rw
    working_dir: /app
    command:
      - bash
      - -c
      - "pip install -q /app/mistralai_stub && pip install -q -e /r2r[core] && pip install -q -e . && alembic upgrade head && exec python -m app.main"
  worker-lo:
    volumes:
      - ./platform/backend:/app:rw
      - ./R2R/py:/r2r:rw
