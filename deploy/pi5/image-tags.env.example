# deploy/pi5/image-tags.env.example — per-service image tags for pi5.
#
# Consumed via `env_file: [.env, image-tags.env]` on every adamaton-* service
# in deploy/pi5/docker-compose.yml. Copy to image-tags.env on first deploy
# (cp image-tags.env.example image-tags.env); the deploy-agent rewrites the
# affected line in place on every POST /deploy/restart?service=X&tag=Y call.
#
# Tag forms (see deploy/pi5/MANIFEST.yaml):
#   "main"           — always-latest from origin/main on the workstation registry
#   "sha-abc1234"    — immutable, reproducible (preferred for production)
#   "v0.2.0"         — semver tag
#
# Two services share an image (so they MUST share a tag var, kept in sync
# by the deploy-agent's allow-list):
#   - nano-research      + nano-research-worker → ADAMATON_NANO_RESEARCH_TAG
#   - backend (Python)   + worker-lo            → ADAMATON_BACKEND_TAG

ADAMATON_AUDIT_MONITOR_TAG=main
ADAMATON_BACKEND_TAG=main
ADAMATON_FEDERATION_MONITOR_TAG=main
ADAMATON_FINALIZE_BOT_TAG=main
ADAMATON_LEDGER_MONITOR_TAG=main
ADAMATON_DATASET_WORKER_TAG=main
ADAMATON_DEPLOY_AGENT_TAG=main
ADAMATON_EVO_API_TAG=main
ADAMATON_FIGURE_RENDERER_TAG=main
ADAMATON_NANO_RESEARCH_TAG=main
ADAMATON_PLUGIN_HOST_TAG=main
ADAMATON_R2G_TAG=main
ADAMATON_SKILLS_RAE_TAG=main
ADAMATON_SKILLS_RAE_WORKER_TAG=main

# Unified worker (full variant on pi5). Pins the
# adamaton-worker-full:<tag> image; the variant is in the image name,
# not the tag, so ADAMATON_WORKER_TAG="main" or "sha-abc1234" is right.
ADAMATON_WORKER_TAG=main

# DEPRECATED — kept for one release cycle so `bin/adam deploy --rollback`
# can re-spawn the standalone workers from a previous umbrella SHA. New
# nodes should pin only ADAMATON_WORKER_TAG above. Remove these vars
# after the rollback window closes.
ADAMATON_DISPATCH_WORKER_TAG=main
ADAMATON_EVO_WORKER_TAG=main
ADAMATON_REINDEX_WORKER_TAG=main
ADAMATON_SKILLS_WORKER_TAG=main
