# deploy/pi5/.env.example — copy to .env on the Pi (NOT committed). up.sh
# rsyncs this directory minus .env, so the Pi keeps its own secrets.

# ---- Image tag ----------------------------------------------------------
# Stamped by up.sh from `git rev-parse --short HEAD` in the umbrella.
# A literal value here is only used for first-deploy bootstrap; the live
# value comes through as an env var on `docker compose up`.
IMAGE_TAG=dev

# ---- Postgres ------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ---- Workstation (sidecars + vLLM live here) ----------------------------
# IP of the GPU/workstation host on the same LAN; BGE/Octen sidecars listen
# on 8089/8090, vLLM on 9080. Used both by extra_hosts entries and by the
# sidecar URL env vars below.
WORKSTATION_IP=10.0.4.37
BGE_SIDECAR_URL=http://10.0.4.37:8089
OCTEN_SIDECAR_URL=http://10.0.4.37:8090

# ---- LLM endpoints (workstation vLLM) -----------------------------------
OPENAI_API_BASE=http://10.0.4.37:9080/v1
QWEN_BASE_URL=http://10.0.4.37:9080/v1
QWEN_MODEL=qwen3.6-27b-nvfp8
QWEN_MODEL_ID=qwen3.6-27b-nvfp8
R2G_LLM_MODEL=qwen3.6-27b-nvfp8

# ---- r2g ----------------------------------------------------------------
# Owner UUID assigned to documents that arrive without an explicit owner.
R2G_DEFAULT_OWNER_ID=2acb499e-8428-543b-bd85-0d9098718220

# ---- evo-api ------------------------------------------------------------
# Bearer token Caddy injects on /evo-api/* requests. Generate with
# `openssl rand -hex 32` — keep this out of git.
EVO_API_TOKEN=replace-me-openssl-rand-hex-32
GITEA_BASE_URL=http://localhost
# Host path for the LLM agent memory volumes bind-mounted into evo-api.
AGENT_MEMORY_DIR=/home/sirus/agent-memory

# ---- Python backend (R2R) ----------------------------------------------
LITELLM_LOG=INFO

# ---- nano-research log verbosity ----------------------------------------
NANO_RESEARCH_LOG_LEVEL=info

# ---- Third-party API keys (consumed by platform/backend) ----------------
SEMANTIC_SCHOLAR_API_KEY=
TAVILY_API_KEY=
GITHUB_TOKEN=
PLUGIN_HOST_SECRET_KEY=
RESEARCH_GRAPHRAG_COMMUNITIES=1

# Volume + container naming. MUST stay 'deepresearch' for the cutover from
# the legacy ~/deepresearch/ compose so that the existing named volumes
# (deepresearch_pg_data, deepresearch_dr_uploads, deepresearch_nano_workspace,
# deepresearch_redis_data, deepresearch_caddy_data, deepresearch_caddy_config,
# deepresearch_reranker_hf_cache) keep binding to the same postgres / redis /
# caddy / uploads / nano-workspace data. Future generations of this stack may
# rename to 'adamaton' when an explicit data migration is performed.
COMPOSE_PROJECT_NAME=deepresearch
