# /thearray/gogents/configs/worker.env.example
# Example environment configuration for the PR review worker.
# Copy this file to /etc/gogents/worker.env and adjust values for your
# environment. Do NOT commit your real worker.env to source control.

# --- Temporal ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=pr-review

# --- Worker identity & concurrency ---
WORKER_IDENTITY=pr-review-worker-prod-1
MAX_CONCURRENT_ACTIVITIES=10
MAX_CONCURRENT_WORKFLOWS=5

# --- LLM backend (preferred) ---
# Backend can be: vllm, openai, anthropic, etc. (see internal/llm).
LLM_BACKEND=vllm
LLM_ENDPOINT=http://localhost:8000
LLM_MODEL_NAME=
LLM_API_KEY=
LLM_DEFAULT_MAX_TOKENS=512
LLM_DEFAULT_TEMPERATURE=0.1
LLM_TIMEOUT=2m
LLM_RETRY_ATTEMPTS=3
LLM_USE_CHAT_API=true

# --- Legacy vLLM-only configuration (kept for backward compat) ---
# vLLM native API uses the /generate path; the LLM_ENDPOINT above is for the
# OpenAI-compat client which appends /v1/chat/completions itself.
VLLM_ENDPOINT=http://localhost:8000/generate

# --- Gitea integration (preferred) ---
GITEA_BASE_URL=https://gitea.example.com
GITEA_TOKEN=
GITEA_WEBHOOK_SECRET=

# --- GitHub integration (alternative) ---
# Either Gitea or GitHub must be configured; both can coexist.
GITHUB_TOKEN=

# --- MCP Server (if used) ---
MCP_SERVER_URL=http://localhost:3000

# --- Logging ---
LOG_LEVEL=info

# --- Workflow tuning ---
GOGENTS_WORKFLOW_PASS_THRESHOLD=0.75
GOGENTS_WORKFLOW_MERGE_METHOD=squash
GOGENTS_WORKFLOW_REQUIRE_ALL_CRITICAL=true
GOGENTS_WORKFLOW_BLOCK_ON_CRITICAL=true

# --- Performance tuning ---
ACTIVITY_TIMEOUT_MINUTES=3
VLLM_REQUEST_TIMEOUT_SECONDS=120
MCP_REQUEST_TIMEOUT_SECONDS=30
