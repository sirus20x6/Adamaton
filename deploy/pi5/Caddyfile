# deploy/pi5/Caddyfile — Adamaton edge reverse proxy.
#
# Ported verbatim from pi5:~/deepresearch/infra/Caddyfile on 2026-05-16.
# Routes to upstream Go services and the Python platform backend; the SPA
# falls through as the default handler with index.html try-files.
#
# Browser will see a "not trusted" warning the first time per device until
# you install Caddy's root cert (printed at startup, also at
# /data/caddy/pki/authorities/local/root.crt inside the caddy container).

deepresearch.local, deepresearch, adamaton.local, adamaton {
    tls internal

    encode gzip

    # PostgREST read API — must precede the broader API routes.
    @db path /db/*
    handle @db {
        uri strip_prefix /db
        reverse_proxy postgrest:3000
    }

    # WebSocket — must precede the broader API routes.
    @ws path /ws/*
    handle @ws {
        reverse_proxy backend:7272 {
            transport http {
                read_timeout 24h
            }
        }
    }

    # r2g full cutover (2026-05-14): the audited /v3 endpoints come from the
    # Go reimplementation. Anything else under /v3/* falls through to R2R
    # via the @api block below.
    @r2g {
        path /v3/documents /v3/documents/* /v3/chunks /v3/chunks/* /v3/retrieval/search
    }
    handle @r2g {
        reverse_proxy r2g:7373 {
            transport http {
                read_timeout 600s
            }
        }
    }

    # /platform/* r2g cutover (2026-05-15): figures + sources + corpora + graph
    # endpoints are owned by the Go r2g service now.
    @platform_r2g {
        path /platform/figures /platform/figures/* /platform/sources /platform/sources/ /platform/sources/* /platform/corpora /platform/corpora/* /platform/graph /platform/graph/*
    }
    handle @platform_r2g {
        reverse_proxy r2g:7373 {
            transport http {
                read_timeout 600s
            }
        }
    }

    # NanoResearch SSE-aware proxy. /api/v1/nano/* → nano-research:7378.
    # flush_interval -1 disables response buffering for the /events stream.
    @nano_research {
        path /api/v1/nano /api/v1/nano/*
    }
    handle @nano_research {
        uri strip_prefix /api
        reverse_proxy nano-research:7378 {
            flush_interval -1
            transport http {
                read_timeout 1800s
            }
        }
    }

    # SkillRAE retrieval + context compilation service.
    @skills_rae {
        path /platform/skills/rae /platform/skills/rae/*
    }
    handle @skills_rae {
        uri strip_prefix /platform/skills/rae
        reverse_proxy skills-rae:7376 {
            transport http {
                read_timeout 60s
            }
        }
    }

    # plugin-host (Go) supervises plugin subprocesses (gRPC over Unix sockets).
    @plugin_host {
        path /platform/plugins /platform/plugins/* /platform/importers /platform/importers/* /platform/search /platform/search/* /platform/marketplace /platform/marketplace/* /platform/zotero /platform/zotero/*
    }
    handle @plugin_host {
        reverse_proxy plugin-host:7375 {
            transport http {
                read_timeout 600s
            }
        }
    }

    # Backend REST API + platform routers (Python fallback).
    @api path /v3/* /platform/*
    handle @api {
        reverse_proxy backend:7272 {
            transport http {
                read_timeout 300s
            }
        }
    }

    # evo-api dashboard/aggregator. Server-side bearer auth injected so the
    # React bundle in the SPA below can talk to it same-origin without ever
    # seeing the token. Strips the /evo-api prefix on the way out.
    @evoapi path /evo-api/*
    handle @evoapi {
        # no-store on the responses so a transient bad-routing day
        # (e.g. when a path fell through to the SPA HTML fallback and
        # axios cached the HTML as the response for that XHR URL)
        # can't poison the browser cache. API responses are short-lived
        # anyway; nothing to gain from letting them be re-served stale.
        header Cache-Control "no-store"
        uri strip_prefix /evo-api
        request_header Authorization "Bearer {env.EVO_API_TOKEN}"
        reverse_proxy evo-api:9123 {
            transport http {
                read_timeout 1800s
            }
        }
    }

    # SPA-bundle fallback: the React bundle was built with empty
    # VITE_EVO_API_BASE (the `?? "/evo-api"` default only fires on
    # null/undefined, not on an empty string set at build time), so it
    # hits bare /api/v1/{delegator,workflows,evo,system}/* directly.
    # Route those to evo-api with the same bearer injection. Note:
    # /api/v1/nano/* is claimed earlier by @nano_research; this matcher
    # only catches what evo-api owns.
    @evoapi_bare path /api/v1/delegator/* /api/v1/workflows/* /api/v1/evo/* /api/v1/system/* /api/v1/health* /api/v1/dashboard/* /api/v1/llm/* /api/v1/skills/* /api/v1/workers* /api/v1/workers/* /api/v1/racks /api/v1/jobs* /api/v1/jobs/* /api/v1/memory/* /api/v1/research/*
    handle @evoapi_bare {
        # See @evoapi block above for why no-store on API responses.
        header Cache-Control "no-store"
        request_header Authorization "Bearer {env.EVO_API_TOKEN}"
        reverse_proxy evo-api:9123 {
            transport http {
                read_timeout 1800s
            }
        }
    }

    # Push-deploy receiver. /deploy/health is unauth; all other endpoints
    # require the bearer in DEPLOY_AGENT_TOKEN (checked by the agent itself).
    @deploy_agent path /deploy/*
    handle @deploy_agent {
        uri strip_prefix /deploy
        reverse_proxy deploy-agent:9128
    }

    # v1.0 / v1.1 on-chain observability daemons. Each daemon's HTTP
    # surface is bound to 0.0.0.0 inside its own container; Caddy is
    # what enforces the public-loopback boundary. The frontend Network
    # section calls /network-api/<daemon>/<path>; we strip the prefix
    # so the daemon sees its own native path.
    #
    # Daemons currently wired: audit-monitor. Federation / ledger /
    # finalize-bot will join as their compose services land.
    @audit_monitor path /network-api/audit/*
    handle @audit_monitor {
        header Cache-Control "no-store"
        uri strip_prefix /network-api/audit
        reverse_proxy audit-monitor:9275
    }
    @federation_monitor path /network-api/federation/*
    handle @federation_monitor {
        header Cache-Control "no-store"
        uri strip_prefix /network-api/federation
        reverse_proxy federation-monitor:9276
    }
    @ledger_monitor path /network-api/ledger/*
    handle @ledger_monitor {
        header Cache-Control "no-store"
        uri strip_prefix /network-api/ledger
        reverse_proxy ledger-monitor:9277
    }

    # SPA: static file server with index.html fallback.
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    request_body {
        max_size 256MB
    }
}

# Plain HTTP → HTTPS redirect; also catches LAN-IP bookmarks.
http://deepresearch.local, http://deepresearch, http://adamomaton.local, http://adamomaton, http://10.0.4.30, http://10.0.4.31 {
    redir https://adamomaton.local{uri} permanent
}
