# GoGents development configuration template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Gitea Configuration (Primary)
# -----------------------------------------------------------------------------
GITEA_BASE_URL=http://localhost:3000
GITEA_TOKEN=your_gitea_token_here
GITEA_WEBHOOK_SECRET=generate_a_long_random_secret
GITEA_ADMIN_USER=gitea
GITEA_DOMAIN=localhost

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
# Leave API_BIND_ADDRESS on loopback for local development. Set API_TOKEN before
# binding to 0.0.0.0 or another public interface.
API_BIND_ADDRESS=127.0.0.1
API_TOKEN=
# CORS allowlist for the API server. Defaults to the project port allowlist:
#   3000  - Gitea / generic frontends
#   5173  - Vite dev server
#   7891  - Demo UI
#   9123  - apiserver
# Port 8080 is intentionally NOT included (banned project-wide).
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:7891,http://localhost:9123
# Pass 12: cap on concurrent workflows the API server may have in flight.
# Excess starts return 503. Default: 50.
GOGENTS_APISERVER_MAX_INFLIGHT_WORKFLOWS=50

# -----------------------------------------------------------------------------
# vLLM AI Backend
# -----------------------------------------------------------------------------
# vLLM uses the native /generate endpoint by default; the OpenAI-compat LLM
# client appends /v1/chat/completions itself. Match the Go default so a fresh
# .env doesn't silently re-target the wrong URL.
VLLM_ENDPOINT=http://localhost:8000/generate
# Cap on concurrent connections to the vLLM/MCP host so a fan-out of activities
# cannot saturate the upstream. Default: 20.
VLLM_MAX_CONCURRENT=20
MCP_SERVER_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Temporal Workflow Engine
# -----------------------------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=pr-review

# -----------------------------------------------------------------------------
# GitHub Token (for MCP server)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG
# Log output format. "json" (default) for structured ingestion; "text" for
# human-readable dev output. Mapped to cfg.Logging.Format.
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Webhook listener
# -----------------------------------------------------------------------------
# Port the gitea-webhook listener binds to. Default 8090.
WEBHOOK_PORT=8090
# When set to "true", allows webhook traffic without HMAC signature
# verification. ONLY use this for local development — never in production.
GOGENTS_ALLOW_UNSIGNED_WEBHOOKS=false
# Pass 11: cap on concurrent webhook deliveries in flight; protects the worker
# from a webhook flood. Default: 50.
GOGENTS_WEBHOOK_MAX_INFLIGHT=50

# -----------------------------------------------------------------------------
# Gitea TLS (advanced)
# -----------------------------------------------------------------------------
# Set to "true" to skip Gitea TLS certificate verification. Required when
# Gitea is fronted by a self-signed cert. Default: false. Strongly discouraged
# outside of dev/test environments.
GOGENTS_ALLOW_INSECURE_GITEA_TLS=false

# -----------------------------------------------------------------------------
# Plugin loader (workers)
# -----------------------------------------------------------------------------
# When "true", the worker fails fast if any plugin fails to load OR if zero
# plugin nodes are registered. Default: false.
GOGENTS_REQUIRE_PLUGINS=false

# -----------------------------------------------------------------------------
# Delegator service (LLM agent execution)
# -----------------------------------------------------------------------------
# URL of the delegator MCP service used by the agent_executor. Default
# http://localhost:9123 (the evo dashboard's unified port; the old :3141
# Svelte dashboard was retired on 2026-05-08).
GOGENTS_DELEGATOR_URL=http://localhost:9123

# -----------------------------------------------------------------------------
# HTTP executor (SSRF guard)
# -----------------------------------------------------------------------------
# When "true", the HTTP executor will accept private/loopback IP destinations
# (RFC 1918, 127.0.0.0/8, etc). Default: false. Only enable in trusted dev
# environments where you intentionally call internal services.
GOGENTS_HTTP_EXECUTOR_ALLOW_PRIVATE=false

# When ALLOW_PRIVATE=true, you MUST also list the explicit hosts/CIDRs that
# may be reached. Without this, the executor refuses to start. Format is
# comma-separated; entries are hostnames (matched literally) or CIDRs.
# Examples:
#   GOGENTS_HTTP_EXECUTOR_ALLOW_HOSTS=localhost,127.0.0.1/32,10.0.0.0/8
GOGENTS_HTTP_EXECUTOR_ALLOW_HOSTS=

# -----------------------------------------------------------------------------
# QuickApps workflow demo
# -----------------------------------------------------------------------------
# Override the directories the QuickApps demo workflow uses for app storage and
# repo mirroring. Defaults to internal paths under the project root.
# QUICKAPPS_APPS_DIR=/var/lib/gogents/quickapps
# QUICKAPPS_MIRROR_DIR=/var/lib/gogents/quickapps-mirror

# -----------------------------------------------------------------------------
# n8n bridge plugin (Node.js sidecar)
# -----------------------------------------------------------------------------
# Per-execution timeout for the /execute endpoint, in milliseconds.
N8N_BRIDGE_EXECUTE_TIMEOUT_MS=60000
# Upstream timeout for HTTP requests issued by the bridge, in milliseconds.
N8N_BRIDGE_UPSTREAM_TIMEOUT_MS=15000
# When "true", disables the SSRF guard that blocks private/loopback IPs.
# Default: false. Same caveats as GOGENTS_HTTP_EXECUTOR_ALLOW_PRIVATE.
N8N_BRIDGE_ALLOW_PRIVATE_IPS=false
# TCP port the bridge listens on. Default: 5679.
N8N_BRIDGE_PORT=5679
# Bind interface. Default: 127.0.0.1 (loopback). When set to a public address
# (0.0.0.0 / ::), N8N_BRIDGE_TOKEN becomes REQUIRED — startup will refuse
# without it.
N8N_BRIDGE_HOST=127.0.0.1
# Bearer token enforced by the bridge. REQUIRED when binding to a public
# address. Generate with: openssl rand -hex 32
N8N_BRIDGE_TOKEN=
# Comma-separated allow-list of n8n node packages. Only packages whose names
# match `n8n-nodes-*` AND appear in this list are loaded.
# Example: N8N_ALLOWED_PACKAGES=n8n-nodes-base,n8n-nodes-mycustom
N8N_ALLOWED_PACKAGES=

# -----------------------------------------------------------------------------
# Budget router service
# -----------------------------------------------------------------------------
# Required when binding the budget router to a public address. Used as a
# bearer token for the /v1/* admin endpoints.
BUDGET_API_TOKEN=

# -----------------------------------------------------------------------------
# Credential store
# -----------------------------------------------------------------------------
# REQUIRED for any code path that uses internal/credentialstore. Must be a
# 32-byte AES-256 key, BASE64-encoded (the store decodes base64, not hex).
# Generate with:
#   openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Deploy fleet (referenced by deploy/*/docker-compose.yml; enforced by
# scripts/check-env-example.sh in `make ci`)
# -----------------------------------------------------------------------------
# Bearer token the deploy-agents require on every /restart /scale /provision
# call; bin/adam ship sends it. Generate with: openssl rand -hex 32
DEPLOY_AGENT_TOKEN=

# Garage (S3-compatible blob store on pi5) inter-node RPC secret.
# Generate with: openssl rand -hex 32
GARAGE_RPC_SECRET=

# GitHub PAT used by services that talk to the GitHub API.
GITHUB_TOKEN=

# Bearer token for the evo-api admin surface (distinct from API_TOKEN).
EVO_API_TOKEN=

# local-deep-research API key (LDR is transient on pi5 until searchcore
# parity retires it — see knowledge/CLAUDE.md).
LDR_API_KEY=

# Fleet addresses: the GPU workstation (registry host) and pi5.
WORKSTATION_IP=10.0.4.37
PI1_HOST=10.0.4.30
