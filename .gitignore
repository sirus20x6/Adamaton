# Adamaton umbrella .gitignore.
#
# Worktrees (umbrella-level + per-submodule) are local-only.
# .locks/*.json are tracked (concurrent claims need to be visible);
# only the .gitkeep is the placeholder.

/worktrees/
/**/*-worktrees/

# Local agent state
/.locks/*.json

# Per-component build artefacts that escape into the umbrella checkout
/bin/*.local
/bin/*.arm64
/bin/*.amd64

# Per-host deploy secrets — .env.example is tracked, .env is local-only
/deploy/*/.env

# Frontend bundle rsynced into deploy/pi5/ at deploy time
/deploy/pi5/frontend-dist/

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Go build cache when a stray go build lands here
/go.sum
